// features_concurrency.tx
import { Thread, Mutex } from "std";

function run(state: object) {
    let m = state.mutex;
    m.lock();
    let c = state.count;
    let temp = c + 1;
    state.count = temp;
    m.unlock();
}

function main() {
    print("Starting threads test...");

    let state = {
        count: 0,
        mutex: new Mutex()
    };

    // Create threads passing shared state
    let t1 = new Thread(run, state);
    let t2 = new Thread(run, state);

    t1.join();
    t2.join();

    let final = state.count;
    print("Final count: Expected: 2, Actual: ", final);

    if (final == 2) {
        print("Concurrency Test: Expected: SUCCESS, Actual: SUCCESS");
    } else {
        print("Concurrency Test: Expected: SUCCESS, Actual: FAILURE");
    }
}
