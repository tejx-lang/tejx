function main(): void {
    print("--- Structural Type Test ---");
    
    // Structural Type Declaration
    let point: { x: int32, y: int32 } = {
        x: 10,
        y: 20
    };
    
    print("Point: Expected: 10, 20, Actual: ", point.x, ", ", point.y);
    
    print("--- End Test ---");
}
