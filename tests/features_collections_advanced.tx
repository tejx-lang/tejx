import { 
    Stack, Queue, MinHeap, MaxHeap, Map, Set, OrderedMap, OrderedSet, BloomFilter, Trie,
    push, pop, peek, enqueue, dequeue, insert, extractMin, insertMax, extractMax,
    isEmpty, size, put, at, has, add, contains, find, addPath
} from "std:collections";

print("--- Testing MinHeap & MaxHeap ---");
let minH = MinHeap();
insert(minH, 50); insert(minH, 10); insert(minH, 30);
print("MinHeap extractMin (10): ", extractMin(minH));
print("MinHeap extractMin (30): ", extractMin(minH));

let maxH = MaxHeap();
insertMax(maxH, 10); insertMax(maxH, 50); insertMax(maxH, 30);
print("MaxHeap extractMax (50): ", extractMax(maxH));
print("MaxHeap extractMax (30): ", extractMax(maxH));

print("\n--- Testing OrderedMap & OrderedSet ---");
let om = OrderedMap();
put(om, "b", 2);
put(om, "a", 1);
put(om, "c", 3);
print("OrderedMap get 'a' (1): ", at(om, "a"));
print("OrderedMap size (3): ", size(om));

let os = OrderedSet();
add(os, 100); add(os, 50); add(os, 200);
print("OrderedSet has 50 (true): ", has(os, 50));
print("OrderedSet has 99 (false): ", has(os, 99));

print("\n--- Testing BloomFilter ---");
let bf = BloomFilter(100, 3);
add(bf, "apple");
add(bf, "banana");
print("BloomFilter contains 'apple' (true): ", contains(bf, "apple"));
print("BloomFilter contains 'orange' (false): ", contains(bf, "orange"));

print("\n--- Testing Trie ---");
let t = Trie();
addPath(t, "hello", 1);
addPath(t, "world", 2);
print("Trie find 'hello' (1): ", find(t, "hello"));
print("Trie find 'world' (2): ", find(t, "world"));
print("Trie find 'hell' (0): ", find(t, "hell"));

print("\nAdvanced Collections test complete!");
