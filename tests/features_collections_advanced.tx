import { 
    Stack, Queue, MinHeap, MaxHeap, Map, Set, OrderedMap, OrderedSet, BloomFilter, Trie
} from "std:collections";

function main() {
    print("--- Testing MinHeap & MaxHeap ---");
    let minH = new MinHeap();
    minH.insert(50); minH.insert(10); minH.insert(30);
    print("MinHeap extractMin (10): ", minH.extractMin());
    print("MinHeap extractMin (30): ", minH.extractMin());

    let maxH = new MaxHeap();
    maxH.insertMax(10); maxH.insertMax(50); maxH.insertMax(30);
    print("MaxHeap extractMax (50): ", maxH.extractMax());
    print("MaxHeap extractMax (30): ", maxH.extractMax());

    print("\n--- Testing OrderedMap & OrderedSet ---");
    let om = new OrderedMap();
    om.put("b", 2);
    om.put("a", 1);
    om.put("c", 3);
    print("OrderedMap get 'a' (1): ", om.at("a"));
    print("OrderedMap size (3): ", om.size());

    let os = new OrderedSet();
    os.add(100); os.add(50); os.add(200);
    print("OrderedSet has 50 (true): ", os.has(50));
    print("OrderedSet has 99 (false): ", os.has(99));

    print("\n--- Testing BloomFilter ---");
    let bf = new BloomFilter(100, 3);
    bf.add("apple");
    bf.add("banana");
    print("BloomFilter contains 'apple' (true): ", bf.contains("apple"));
    print("BloomFilter contains 'orange' (false): ", bf.contains("orange"));

    print("\n--- Testing Trie ---");
    let t = new Trie();
    t.addPath("hello", 1);
    t.addPath("world", 2);
    print("Trie find 'hello' (1): ", t.find("hello"));
    print("Trie find 'world' (2): ", t.find("world"));
    print("Trie find 'hell' (0): ", t.find("hell"));

    print("\nAdvanced Collections test complete!");
}
