
import std:net;
import std:http;

print("--- Testing Net/HTTP Module ---");

// Test HTTP Sync
print("Fetching http://example.com (Sync)...");
let res = http.getSync("http://example.com");
if (res) {
    print("Response received (Sync), length: " + res.length);
    assert(res.length > 0);
} else {
    print("Failed to fetch (Sync)");
}

// Test HTTP Async
async function test_async_http() {
    print("Fetching http://example.com (Async)...");
    let res = await http.get("http://example.com");
    if (res) {
        print("Response received (Async), length: " + res.length);
        assert(res.length > 0);
    } else {
        print("Failed to fetch (Async)");
    }
}

let p = test_async_http();
await p;
print("Async HTTP test passed");

// Test TCP (Connect only)
print("Connecting to google.com:80 (TCP)...");
// tcp connect expects "host:port" string
let stream = net.connect("google.com:80");
// net.connect returns -1 on failure, or a stream ID (which is an object index, so > 0 usually, or 0 if first object?)
// Runtime code: `heap.insert(id, ...); id`. 
// If successful, it returns an ID.
print("Stream ID: " + stream);

if (stream >= 0) {
    print("Connected successfully");
    net.close(stream);
    print("Closed stream");
} else {
    print("Failed to connect");
}
