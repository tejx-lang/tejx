// Object Oriented Programming: Classes, Protocols, Extensions
// ==========================================================

// 1. Interfaces
// -------------------------
interface Greeter {
    greet(name: string): void;
}

// 2. Classes
// ----------
class Entity {
    id: int32;
    constructor(id: int32) {
        this.id = id;
    }
}

class Robot extends Entity {
    model: string;

    constructor(id: int32, model: string) {
        super(id); 
        this.id = id;
        this.model = model;
    }

    identify(): void {
        print("Robot Model: Expected: T-800, Actual: ", this.model, " (ID: Expected: 101, Actual: ", this.id, ")");
    }
}

// 3. Extension Implementing Interface
// ----------------------------------
extension Robot {
    greet(name: string): void {
        print("BEEP BOOP. Hello ", name, ". Expected: Human, Actual: ", name);
    }
    
    // Additional method in extension
    status(): string {
        return "Operational";
    }
}

// 4. Usage
// --------
print("--- OOP Demo ---");
let r = new Robot(101, "T-800");

r.identify();       // Class method
r.greet("Human");   // Interface method via Extension
print("Status: Expected: Operational, Actual: ", r.status()); // Extension method

class Point {
    x: int32;
    y: int32;

    constructor(x: int32, y: int32) {
        this.x = x;
        this.y = y;
    }

    print(): void {
        print("Point: Expected: 10, 20, Actual: ", this.x, ", ", this.y);
    }
}

function runMemorySafety(): void {
    print("--- Memory Safety Demo ---");
    print("Entering block...");
    {
        let p: Point = new Point(10, 20);
        p.print();
        print("Exiting block...");
    }
    print("Block exited. Point should be freed.");
}
runMemorySafety();

interface Printable {
    toString(): string;
    print(prefix: string): void;
}

class User implements Printable {
    name: string;
    constructor(n: string) {
        this.name = n;
    }
    
    toString(): string {
        return "User: " + this.name;
    }
    
    print(prefix: string): void {
        print(prefix + "Expected: User: TejX, Actual: " + this.toString());
    }
}

class Document implements Printable {
    content: string;
    constructor(c: string) {
        this.content = c;
    }
    
    toString(): string {
        return "Doc: " + this.content;
    }
    
    print(prefix: string): void {
        print(prefix + "Expected: Doc: Hello World, Actual: " + this.toString());
    }
}

// Function accepting Interface
function printAny(p: Printable) {
    p.print(">> ");
}

let uProto = new User("TejX");
let dProto = new Document("Hello World");

printAny(uProto);
printAny(dProto);

// Extensions Feature Test
class ExtensibleUser {
    name: string;
    constructor(n: string) {
        this.name = n;
    }
}

extension ExtensibleUser {
    sayHello() {
        print("sayHello: Expected: Hello, Tej, Actual: Hello, ", this.name);
    }
    
    greet(times: int32) {
        let i = 0;
        while (i < times) {
            print("Greeting ", (i + 1), ": Expected: ", this.name, ", Actual: ", this.name);
            i = i + 1;
        }
    }
}

let uExt = new ExtensibleUser("Tej");
uExt.sayHello();
uExt.greet(3);

print("Extensions test complete!");

// OOP Polish Test
class BankAccount {
    private balance: int32 = 0;
    public owner: string;
    static bankName: string = "TejXBank";

    constructor(owner: string, initialBalance: int32) {
        this.owner = owner;
        this.balance = initialBalance;
    }

    public deposit(amount: int32): void {
        this.balance += amount;
        print("Deposited: ", amount);
    }

    public getBalance(): int32 {
        return this.balance;
    }
    
    static getBankName(): string {
        return BankAccount.bankName;
    }
}

print("Bank: Expected: TejXBank, Actual: ", BankAccount.getBankName());

let acc = new BankAccount("Alice", 100);
print("Owner: Expected: Alice, Actual: ", acc.owner);
acc.deposit(50);
print("Balance: Expected: 150, Actual: ", acc.getBalance());

// Getter/Setter Test
class Person {
    _name: string = "";
    _age: int32 = 0;
    
    constructor(name: string, age: int32) {
        this._name = name;
        this._age = age;
    }
    
    // Getter for name
    get name(): string {
        return this._name;
    }
    
    // Setter for name
    set name(value: string) {
        this._name = value;
    }
    
    // Getter for age
    get age(): int32 {
        return this._age;
    }
    
    // Setter for age
    set age(value: int32) {
        if (value >= 0) {
            this._age = value;
        }
    }
    
    // Computed getter
    get info(): string {
        return this._name + " is " + this._age + " years old";
    }
}

print("=== Getter/Setter Test ===");

let p = new Person("Alice", 30);

// Test getters
print("Name: Expected: Alice, Actual: ", p.name);
print("Age: Expected: 30, Actual: ", p.age);
print("Info: Expected: Alice is 30 years old, Actual: ", p.info);

// Test setters
p.name = "Bob";
p.age = 25;
print("After update - Name: Expected: Bob, Actual: ", p.name);
print("After update - Age: Expected: 25, Actual: ", p.age);

print("=== Getter/Setter Test Complete ===");

print("--- Ternary Operator ---");
let age = 18;
let status = age >= 18 ? "Adult" : "Minor";
print("Status: Expected: Adult, Actual: ", status);
print("10 > 5: Expected: 10 is bigger, Actual: ", (10 > 5 ? "10 is bigger" : "5 is bigger"));

print("--- Switch (Desugared) ---");
let fruit = "Apple";

switch (fruit) {
    case "Banana":
        print("Result: Expected: it is an apple, Actual: banana (wrong)");
        break;
    case "Apple":
        print("Result: Expected: it is an apple, Actual: it is an apple");
        break;
    default:
        print("Result: Unknown fruit.");
}

print("--- Inheritance ---");
class Animal {
    name: string;
    constructor(n: string) {
        this.name = n;
    }
    speak(): void {
        print(this.name, " makes a noise.");
    }
}

class Dog extends Animal {
    breed: string;
    constructor(n: string) {
        super(n);
        this.name = n;
        this.breed = "Unknown";
    }
    
    bark(): void {
        print(this.name, " barks!");
    }

    speak(): void {
        print("Dog overrides speak:");
        super.speak();
    }
}

let dDog = new Dog("Rex");
dDog.speak(); // Makes noise
dDog.bark();  // Barks
print("Dog Name: Expected: Rex, Actual: ", dDog.name);

abstract class Shape {
    protected name: string;
    
    constructor() {
        this.name = "Unknown Shape";
    }
    
    abstract area(): int32;
    
    describe(): void {
        print("I am a ", this.name);
    }
}

class Circle extends Shape {
    private radius: int32;
    
    constructor(r: int32) {
        super();
        this.name = "Circle"; 
        this.radius = r;
    }
    
    area(): int32 {
        return 3.14 * this.radius * this.radius;
    }
    
    printDetails(): void {
        super.describe();
        print("My area: Expected: 12.56, Actual: ", this.area());
    }
}

function run_shape() {
    let c = new Circle(2);
    c.printDetails();
}

run_shape();

class Cat extends Animal {
    constructor(n: string) { super(n); }
}

let d = new Dog("Buddy");
let c = new Cat("Whiskers");

print("d is Dog: Expected: 1, Actual: ", (d instanceof Dog));      
print("d is Animal: Expected: 1, Actual: ", (d instanceof Animal)); 
print("d is Cat: Expected: 0, Actual: ", (d instanceof Cat));       

if (d instanceof Dog) {
    print("Verified: d is a Dog: Expected: pass, Actual: pass");
}

if (c instanceof Animal) {
    print("Verified: c is an Animal: Expected: pass, Actual: pass");
}

print("Instanceof test complete!");

// Polymorphism Check
let animals: Animal[] = [d, c];
print("\n--- Polymorphism Check ---");
animals.forEach(a => {
    print("Item is Animal: ", (a instanceof Animal));
});

print("=== OOP Test Complete ===");
