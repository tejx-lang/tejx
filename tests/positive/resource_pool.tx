
// Resource Pool Pattern - Strict Ownership
// ==========================================
import {assert_true, assert_eq_int} from "../positive/utils.tx";
class Resource {
    id: int32;
    active: bool;

    constructor(id: int32) {
        this.id = id;
        this.active = true;
        print("Resource Constructed:", this.id);
    }
}

class ResourcePool {
    pool: Resource[];

    constructor() {
        this.pool = [];
        // Add some resources
        this.pool.push(new Resource(1));
        this.pool.push(new Resource(2));
    }

    acquire(): Resource | None {
        if (this.pool.length > 0) {
            return this.pool.pop();
        }
        return None;
    }

    release(r: Resource | None) {
        if (r != None) {
             print("Releasing Resource:", r.id);
             this.pool.push(r);
        }
    }
}

// Function consuming resource removed.
// Use 'print' directly or add method to Resource.

function main() {
    print("--- Resource Pool Test ---");
    let pool = new ResourcePool();

    print("Acquiring 1...");
    let r1 = pool.acquire(); 
    // r1 is now owned by this scope.
    assert_true(r1 != None, "Resource acquired");
    if (r1 != None) {
        assert_eq_int(r1.id, 1, "Resource id");
    }

    print("Acquiring 2...");
    let r2 = pool.acquire();
        assert_true(r2 != None, "Resource acquired");

    if (r2 != None) {
        assert_eq_int(r2.id, 2, "Resource id");
    }


    print("Releasing 1...");
    pool.release(r1);
    // r1 is now Moved. Cannot use r1 here.
    // print(r1.id); // Would be error if uncommented (Use after move)

    print("Releasing 2...");
    pool.release(r2);

    // Acquire again to verify they are back
    print("Acquiring Reused...");
    let r3 = pool.acquire();
    assert_true(r3 != None, "Resource acquired");
    if (r3 != None) {
        assert_eq_int(r3.id, 1, "Resource id");
    }

    print("--- End Test ---");
}
