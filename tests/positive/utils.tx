// Test Utilities for TejX
// =========================

function fail_assert(msg: string, expected: string, actual: string) {
    print("❌ FAIL: " + msg);
    print("   Expected: " + expected);
    print("   Actual:   " + actual);
    throw new Error(
        "AssertionFailed: " + msg + " | Expected: " + expected + " | Actual: " + actual
    );
}

export function assert_eq_int(expected: int, actual: int, msg: string) {
    if (expected == actual) {
        print("✅ PASS: " + msg + " - Expected: " + expected + ", Actual: " + actual);
    } else {
        fail_assert(msg, "" + expected, "" + actual);
    }
}

export function assert_eq_float(expected: float, actual: float, msg: string) {
    if (expected == actual) {
        print("✅ PASS: " + msg + " - Expected: " + expected + ", Actual: " + actual);
    } else {
        fail_assert(msg, "" + expected, "" + actual);
    }
}

export function assert_eq_string(expected: string, actual: string, msg: string) {
    if (expected == actual) {
        print("✅ PASS: " + msg + " - Expected: '" + expected + "', Actual: '" + actual + "'");
    } else {
        fail_assert(msg, "'" + expected + "'", "'" + actual + "'");
    }
}

export function assert_true(cond: bool, msg: string) {
    if (cond) {
        print("✅ PASS: " + msg + " - Expected: true, Actual: true");
    } else {
        fail_assert(msg, "true", "false");
    }
}

export function assert(cond: bool, msg: string) {
    if (cond) {
        print("✅ PASS: " + msg);
    } else {
        fail_assert(msg, "true", "false");
    }
}

export function assert_false(cond: bool, msg: string) {
    if (!cond) {
        print("✅ PASS: " + msg + " - Expected: false, Actual: false");
    } else {
        fail_assert(msg, "false", "true");
    }
}

export function assert_fail(msg: string) {
    fail_assert(msg, "failure", "failure");
}

export function assert_ne_int(notExpected: int, actual: int, msg: string) {
    if (notExpected != actual) {
        print("✅ PASS: " + msg + " - Not: " + notExpected + ", Got: " + actual);
    } else {
        fail_assert(msg, "not " + notExpected, "" + actual);
    }
}

export function assert_ne_string(notExpected: string, actual: string, msg: string) {
    if (notExpected != actual) {
        print("✅ PASS: " + msg + " - Not: '" + notExpected + "', Got: '" + actual + "'");
    } else {
        fail_assert(msg, "not '" + notExpected + "'", "'" + actual + "'");
    }
}

export function assert_eq_none(actual: Optional<int>, msg: string) {
    if (actual == None) {
        print("✅ PASS: " + msg + " - Expected: None, Actual: None");
    } else {
        fail_assert(msg, "None", "" + actual);
    }
}
