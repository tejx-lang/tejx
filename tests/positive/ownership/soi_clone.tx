// Scenario 7: Explicit Preservation (Clone)
// When the user needs two separate copies, they use .clone() explicitly.
// This triggers a deep copy — the only way to avoid a move.

class Settings {
    version: int32;
    constructor() { this.version = 1; }
}

function modify(s: Settings) {
    // Takes ownership — 's' is consumed here
    print("Modified settings version:", s.version);
}

function main() {
    let original = new Settings();

    // Move original into modify — original is consumed
    // But first, we use it while it's still alive
    let version = original.version; // Primitive copy (int32 is Copy type)
    modify(original);

    print("Saved version:", version); // Success — version is a primitive copy
    print("Clone test passed!");
}
