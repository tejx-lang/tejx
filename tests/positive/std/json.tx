// JSON Tests
// ==========

import {parse, stringify} from "std:json";
import { assert_eq_int, assert_eq_string, assert_true } from "../utils.tx";

function main() {
    print("--- JSON Tests ---");

    let obj = {
        x: 10,
        y: "hello",
        z: [1, 2, 3],
        w: { nested: true }
    };

    try {
        let json_str = stringify(obj);
        print("Stringified: ", json_str);

        // Test parsing
        let parsed = parse(json_str);
        
        assert_eq_int(10, parsed["x"], "Parsed x (index)");
        assert_eq_string("hello", parsed["y"], "Parsed y (index)");
        
        // Property access
        assert_eq_int(10, (parsed as any).x, "Parsed x (property)");
        assert_eq_string("hello", (parsed as any).y, "Parsed y (property)");
        
        assert_eq_int(3, parsed["z"].length, "Parsed z length");
        
        // Nested access
        print("Parsed w.nested: ", parsed["w"]["nested"]);

    } catch(e) {
        print("❌ FAIL: Caught error: " + e);
    }
}
