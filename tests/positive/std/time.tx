// Time Tests
// ==========
import {delay,sleep,now} from "std:time";
import { assert_eq_int, assert_true } from "../utils.tx";

async function test_delay() {
    print("--- Async Delay ---");
    let t1 = now();
    await delay(500);
    let t2 = now();
    let d = t2 - t1;
    assert_true(d >= 500, "Async delay >= 500ms");
    print("Async delay diff: ", d);
}

function test_sleep() {
    print("--- Sync Sleep ---");
    let start = now();
    sleep(200);
    let end = now();
    let diff = end - start;
    assert_true(diff >= 200, "Sync sleep >= 200ms");
    print("Sync sleep diff: ", diff);
}

async function main() {
    print("=== TIME TESTS START ===");
    let start = now();
    assert_true(start > 0, "time.now() positive");
    
    test_sleep();
    await test_delay();
    
    print("=== TIME TESTS COMPLETE ===");
}
