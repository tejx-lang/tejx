// Network Tests
// =============
import std:net;
import { assert_eq_string, assert_true } from "../utils.tx";

class BoundListener {
    addr: string;
    listener: TcpListener;

    constructor(addr: string, listener: TcpListener) {
        this.addr = addr;
        this.listener = listener;
    }
}

function open_listener(): BoundListener {
    let ports = [43123, 43124, 43125, 43126, 43127, 43128];
    for (let i = 0; i < ports.length(); i++) {
        let addr = "127.0.0.1:" + ports[i];
        try {
            let listener = net.listen(addr);
            return new BoundListener(addr, listener);
        } catch (e) {
        }
    }

    throw new Error("No free local TCP test port");
}

function test_tcp_round_trip() {
    print("--- TCP Round Trip ---");
    let bound = open_listener();
    let listener = bound.listener;
    let client = net.connect(bound.addr);
    assert_true(client != None, "Client connected to local listener");

    let server = listener.accept();
    if (client != None) {
        client.send("ping");
        let incoming = server.receive(16);
        assert_eq_string("ping", incoming, "Server received client payload");

        server.send("pong");
        let reply = client.receive(16);
        assert_eq_string("pong", reply, "Client received server payload");

        client.close();
    }

    server.close();
    listener.close();
}

function test_connect_failure() {
    print("--- TCP Connect Failure ---");
    let stream = net.connect("127.0.0.1:43999");
    assert_true(stream == None, "Connect to unopened port returns None");
}

function main() {
    print("=== NET TESTS START ===");
    test_tcp_round_trip();
    test_connect_failure();
    print("=== NET TESTS COMPLETE ===");
}
