// Math Tests
// ==========

import std:math;
import { assert_eq_int, assert_eq_float, assert_true } from "../utils.tx";

function main() {
    print("--- Math Tests ---");

    // Trigonometry
    let angle: int32 = 3.14159 / 2; // PI/2
    // sin(PI/2) should be close to 1.0
    let s = sin(angle);
    if (s > 0.99) {
        if (s < 1.01) {
             print("✅ PASS: sin(PI/2) ~ 1.0");
        } else {
             print("❌ FAIL: sin(PI/2) too high: " + s);
        }
    } else {
        print("❌ FAIL: sin(PI/2) too low: " + s);
    }
    
    // cos(0) should be 1.0
    assert_eq_float(1.0, cos(0), "cos(0)");

    // Min/Max/Rounding
    assert_eq_int(20, max(10, 20), "max(10, 20)");
    assert_eq_int(10, min(10, 20), "min(10, 20)");
    
    assert_eq_float(3.0, floor(3.9), "floor(3.9)");
    assert_eq_float(5.0, ceil(4.2), "ceil(4.2)");
    assert_eq_float(5.0, round(4.5), "round(4.5)");
    assert_eq_float(4.0, round(4.4), "round(4.4)");
    
    assert_eq_int(10, abs(-10), "abs(-10)");
    assert_eq_float(4.0, sqrt(16), "sqrt(16)");
    assert_eq_int(256, pow(2, 8), "pow(2, 8)");

    // Global min/max/abs wrappers from prelude
     assert_eq_int(10, abs(-10), "global abs(-10)");
     assert_eq_int(10, min(10, 20), "global min(10, 20)");
     assert_eq_int(20, max(10, 20), "global max(10, 20)");

    // Random Simulation
    let r = random();
    if (r >= 0.0) {
        if (r < 1.0) {
            print("✅ PASS: Random number (0-1)");
        } else {
             print("❌ FAIL: Random number >= 1.0: " + r);
        }
    } else {
        print("❌ FAIL: Random number < 0.0: " + r);
    }
}
