// Math Tests
// ==========

import std:math;
import { clamp } from "std:math";
import { randomInt } from "std:math";
import { assert_eq_int, assert_eq_float, assert_true } from "../utils.tx";

function main() {
    print("--- Math Tests ---");

    // Trigonometry
    let angle: float64 = 3.14159265358979 / 2.0; // PI/2
    // sin(PI/2) should be close to 1.0
    let s = sin(angle);
    assert_true(s > 0.99 && s < 1.01, "sin(PI/2) ~ 1.0");
    
    // cos(0) should be 1.0
    assert_eq_float(1.0, cos(0), "cos(0)");
    let quarter = pi() / 4.0;
    let tangent = tan(quarter);
    assert_true(tangent > 0.99 && tangent < 1.01, "tan(PI/4) ~ 1.0");
    let arcSin = asin(1.0);
    assert_true(arcSin > 1.56 && arcSin < 1.58, "asin(1) ~ PI/2");
    let arcCos = acos(1.0);
    assert_true(arcCos > -0.001 && arcCos < 0.001, "acos(1) ~ 0");
    let arcTan = atan(1.0);
    assert_true(arcTan > 0.78 && arcTan < 0.79, "atan(1) ~ PI/4");

    // Min/Max/Rounding
    assert_eq_int(20, max(10, 20), "max(10, 20)");
    assert_eq_int(10, min(10, 20), "min(10, 20)");
    assert_eq_int(-5, min(10, -5), "min(10, -5)");
    
    assert_eq_float(3.0, floor(3.9), "floor(3.9)");
    assert_eq_float(5.0, ceil(4.2), "ceil(4.2)");
    assert_eq_float(5.0, round(4.5), "round(4.5)");
    assert_eq_float(4.0, round(4.4), "round(4.4)");
    
    assert_eq_int(10, abs(-10), "abs(-10)");
    assert_eq_float(4.0, sqrt(16), "sqrt(16)");
    assert_eq_int(256, pow(2, 8), "pow(2, 8)");
    assert_eq_float(1024.0, pow(2, 10), "pow(2, 10)");
    assert_eq_float(0.125, pow(2, -3), "pow(2, -3)");
    assert_eq_float(-8.0, pow(-2, 3), "pow(-2, 3)");
    assert_eq_float(81.0, powi(3, 4), "powi(3, 4)");
    assert_eq_float(0.25, powi(2, -2), "powi(2, -2)");

    // Global min/max/abs wrappers from prelude
    assert_eq_int(10, abs(-10), "global abs(-10)");
    assert_eq_int(10, min(10, 20), "global min(10, 20)");
    assert_eq_int(20, max(10, 20), "global max(10, 20)");
    assert_eq_float(3.141592653589793, pi(), "pi()");
    assert_eq_int(5, clamp(10, 0, 5), "clamp upper");
    assert_eq_int(-1, sign(-10), "sign(-10)");

    // Random Simulation
    seedRandom(123456);
    let seededOne = random();
    seedRandom(123456);
    let seededTwo = random();
    assert_eq_float(seededOne, seededTwo, "seedRandom reproducible");
    let r = random();
    assert_true(r >= 0.0 && r < 1.0, "Random number (0-1)");
    let ri = randomInt(1, 3);
    assert_true(ri >= 1 && ri <= 3, "randomInt range");
}
