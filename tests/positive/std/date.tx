// Date Tests
// ==========

import std:time;
import { assert_eq_string, assert_true } from "../utils.tx";

function main() {
    print("--- Date Tests ---");

    let d = new Date();
    let iso = d.toISOString();
    assert_true(iso.length() > 0, "toISOString returns content");

    let t = d.getTime();
    print("Current timestamp: ", t);

    let currentTime = Date.now();
    print("Date.now(): ", currentTime);
    
    assert_true(currentTime >= t, "Time flow check (Date.now() >= getTime())");
}
