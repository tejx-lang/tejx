import { assert_eq_int, assert_eq_string, assert_true, assert_ne_int } from "../utils.tx";

function main() {
    print("--- Array Methods ---");
    let arr = [1, 2, 3, 4, 5];

    print("--- 1 ---");
    // reduce
    let sum = arr.reduce((acc: int, val: int, idx: int) => {
        return acc + val;
    }, 0);
    print("--- 1b ---");
    assert_eq_int(15, sum, "reduce sum");
    assert_ne_int(0, sum, "reduce not zero");

    print("--- 2 ---");
    // find
    let found = arr.find((val: int, idx: int) => {
        return val == 3;
    });
    print("--- 2b ---");
    assert_eq_int(3, found, "find(3)");

    print("--- 3 ---");
    // findIndex
    let foundIdx = arr.findIndex((val: int, idx: int) => {
        return val == 4;
    });
    print("--- 3b ---");
    assert_eq_int(3, foundIdx, "findIndex(4)");
    assert_ne_int(-1, foundIdx, "findIndex not -1");
    print("--- FINISHED ---");
}
