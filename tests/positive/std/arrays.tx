// Array Tests
// ===========

import { assert_eq_int, assert_eq_string, assert_true, assert_ne_int } from "../utils.tx";

function main() {
    print("--- Array Methods ---");
    let arr = [1, 2, 3, 4, 5];

    // reduce
    let sum = arr.reduce((acc: int, val: int, idx: int) => {
        return acc + val;
    }, 0);
    assert_eq_int(15, sum, "reduce sum");
    assert_ne_int(0, sum, "reduce not zero");

    // find
    let found = arr.find((val: int, idx: int) => {
        return val == 3;
    });
    assert_eq_int(3, found, "find(3)");

    // findIndex
    let foundIdx = arr.findIndex((val: int, idx: int) => {
        return val == 4;
    });
    assert_eq_int(3, foundIdx, "findIndex(4)");
    assert_ne_int(-1, foundIdx, "findIndex not -1");

    // reverse
    let revArr = [1, 2, 3];
    revArr.reverse();
    assert_eq_int(3, revArr[0], "reverse[0]");
    assert_eq_int(2, revArr[1], "reverse[1]");
    assert_eq_int(1, revArr[2], "reverse[2]");

    print("\n--- Array Slice ---");
    let sliceArr = [1, 2, 3, 4, 5];
    // slice(1, 4) -> index 1 to 3 (exclusive 4) -> [2, 3, 4]
    let sliced = sliceArr.slice(1, 4);
    assert_eq_int(3, len(sliced), "Sliced length");
    assert_eq_int(2, sliced[0], "Sliced[0]");
    assert_eq_int(4, sliced[2], "Sliced[2]");

    // len() check from prelude
    let lenArr = [1, 2, 3, 4, 5];
    assert_eq_int(5, len(lenArr), "len(Array)");
    assert_ne_int(0, len(lenArr), "len(Array) not zero");

    // Memory block check
    {
        let tempArr = [1, 2, 3];
        assert_eq_int(3, len(tempArr), "Temp array inside block");
    }
    print("Block exited. Temp array should be freed.");

    print("--- Expanded Array Tests ---");

    // Push/Pop
    let arr2 = [1, 2, 3];
    arr2.push(4);
    assert_eq_int(4, len(arr2), "push length");
    assert_ne_int(3, len(arr2), "push length not original");
    assert_eq_int(4, arr2[3], "push value");

    let popped = arr2.pop();
    assert_eq_int(4, popped, "pop value");
    assert_ne_int(0, popped, "pop value not zero");
    assert_eq_int(3, len(arr2), "pop length");

    // Shift/Unshift
    arr2.unshift(0);
    assert_eq_int(4, len(arr2), "unshift length");
    assert_eq_int(0, arr2[0], "unshift value");

    let shifted = arr2.shift();
    assert_eq_int(0, shifted, "shift value");
    assert_eq_int(3, len(arr2), "shift length");

    // Concat
    let arr3 = [4, 5];
    let merged = arr2.concat(arr3); // [1, 2, 3, 4, 5]
    assert_eq_int(5, len(merged), "concat length");
    assert_ne_int(3, len(merged), "concat not original length");
    assert_eq_int(5, merged[4], "concat value");

    // IndexOf
    assert_eq_int(1, arr2.indexOf(2), "indexOf(2)");
    assert_eq_int(-1, arr2.indexOf(99), "indexOf(99)");

    // Join
    let joined = arr2.join("-");
    assert_eq_string("1-2-3", joined, "join");

    // Map
    let nums = [1, 2, 3];
    let doubled = nums.map((x: int) => x * 2);
    assert_eq_int(2, doubled[0], "map[0]");
    assert_eq_int(4, doubled[1], "map[1]");
    assert_eq_int(6, doubled[2], "map[2]");

    // Filter
    let evens = nums.filter((x: int) => x % 2 == 0);
    assert_eq_int(1, len(evens), "filter length");
    assert_ne_int(3, len(evens), "filter not full length");
    assert_eq_int(2, evens[0], "filter value");

    // ForEach
    let sumForEach = 0;
    nums.forEach((x: int) => {
        sumForEach = sumForEach + x;
    });
    assert_eq_int(6, sumForEach, "forEach sum");

    // Nested Arrays / Matrix
    let matrix = [
        [1, 2],
        [3, 4]
    ];
    assert_eq_int(1, matrix[0][0], "matrix[0][0]");
    assert_eq_int(4, matrix[1][1], "matrix[1][1]");

    let diagSum = 0;
    for(let i=0; i<2; i++) {
        diagSum += matrix[i][i];
    }
    assert_eq_int(5, diagSum, "matrix diagonal sum");
    assert_ne_int(0, diagSum, "matrix diag not zero");
}
