// Advanced Collections Tests
// ==========================
import { 
    Stack, Queue, MinHeap, MaxHeap, Map, Set, OrderedMap, OrderedSet, BloomFilter, Trie
} from "std:collections";
import { Deque } from "std:collections";
import { assert_eq_int, assert_true, assert_false } from "../utils.tx";



import std:collections;

function test_stack(): void {
    print("Testing Stack...");
    let s = new Stack<int>();
    s.push(10);
    s.push(20);
    assert_eq_int(s.size(), 2, "Stack size");
    assert_eq_int(s.pop(), 20, "Stack pop");
    assert_eq_int(s.peek(), 10, "Stack peek");
    print("Stack OK");
}

function test_queue(): void {
    print("Testing Queue...");
    let q = new Queue<int>();
    q.enqueue(1);
    q.enqueue(2);
    assert_eq_int(q.size(), 2, "Queue size");
    assert_eq_int(q.dequeue() , 1, "Queue dequeue");
    print("Queue OK");
}

function test_map(): void {
    print("Testing Map...");
    let m = new Map<string, int>();
    m.reserve(32);
    m.set("key", 123);
    m.set("other", 456);
    m.delete("other");
    m.shrinkToFit();
    assert_true(m.has("key"), "Map has key");
    assert_eq_int(m.get("key"), 123, "Map get key");
    assert_eq_int(m.size(), 1, "Map size");
    print("Map OK");
}

function test_set(): void {
    print("Testing Set...");
    let s = new Set<int>();
    s.add(100);
    s.add(200);
    s.add(100);
    assert_eq_int(s.size(), 2, "Set size");
    assert_true(s.has(100), "Set has 100");
    print("Set OK");
}




function main() {
    print("=== ADVANCED COLLECTIONS START ===");

    let deque = new Deque<int>();
    deque.pushBack(2);
    deque.pushFront(1);
    deque.pushBack(3);
    assert_eq_int(1, deque.popFront(), "Deque popFront");
    assert_eq_int(3, deque.popBack(), "Deque popBack");
    assert_eq_int(1, deque.size(), "Deque size");

    // MinHeap
    let minH = new MinHeap<int>();
    minH.insert(50); minH.insert(10); minH.insert(30);
    assert_eq_int(10, minH.extractMin(), "MinHeap extract 10");
    assert_eq_int(30, minH.extractMin(), "MinHeap extract 30");

    // MaxHeap
    let maxH = new MaxHeap<int>();
    maxH.insertMax(10); maxH.insertMax(50); maxH.insertMax(30);
    assert_eq_int(50, maxH.extractMax(), "MaxHeap extract 50");
    
    // OrderedMap
    let om = new OrderedMap<string, int>();
    om.reserve(8);
    om.put("b", 2); om.put("a", 1);
    assert_eq_int(1, om.at("a"), "OrderedMap get a");
    assert_eq_int(2, om.size(), "OrderedMap size");
    let orderedKeys = om.keys();
    assert_true(orderedKeys[0] == "b" && orderedKeys[1] == "a", "OrderedMap insertion order");
    
    // OrderedSet
    let os = new OrderedSet<int>();
    os.reserve(8);
    os.add(100); os.add(50);
    assert_true(os.has(50), "OrderedSet has 50");
    assert_false(os.has(99), "OrderedSet !has 99");
    let orderedValues = os.values();
    assert_eq_int(100, orderedValues[0], "OrderedSet insertion order");
    
    // BloomFilter
    let bf = new BloomFilter(100, 3);
    bf.add("apple");
    assert_true(bf.contains("apple"), "BloomFilter contains apple");
    assert_false(bf.contains("orange"), "BloomFilter !contains orange");
    
    // Trie
    let t = new Trie();
    t.addPath("hello", 1);
    assert_eq_int(1, t.find("hello"), "Trie find hello");
    assert_eq_int(0, t.find("hell"), "Trie !find hell");
    assert_true(t.startsWith("he"), "Trie startsWith he");
    assert_true(t.delete("hello"), "Trie delete hello");
    assert_false(t.has("hello"), "Trie !has hello after delete");

    test_stack();
    test_queue();
    test_map();
    test_set();

    print("=== ADVANCED COLLECTIONS COMPLETE ===");
}
