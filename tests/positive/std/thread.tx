import { Thread, Mutex, Atomic, Condition, SharedQueue } from "std:thread";
import { assert_eq_int, assert_true } from "../utils.tx";

function test_basic_thread(args: any[]): void {
    let result = args[0] as Atomic;
    result.store(42);
}

function test_mutex_contention(args: any[]): void {
    let mutex = args[0] as Mutex;
    let counter = args[1] as Atomic;
    for (let i = 0; i < 1000; i++) {
        mutex.lock();
        let val = counter.load();
        counter.store(val + 1);
        mutex.unlock();
    }
}

function test_atomic_add(args: any[]): void {
    let counter = args[0] as Atomic;
    for (let i = 0; i < 1000; i++) {
        counter.add(1);
    }
}

function producer(args: any[]): void {
    let q = args[0] as SharedQueue<int>;
    let mutex = args[1] as Mutex;
    let cond = args[2] as Condition;
    for (let i = 0; i < 50; i++) {
        mutex.lock();
        q.enqueue(i);
        cond.notify();
        mutex.unlock();
    }
}

function consumer(args: any[]): void {
    let q = args[0] as SharedQueue<int>;
    let mutex = args[1] as Mutex;
    let cond = args[2] as Condition;
    let total = args[3] as Atomic;
    let count = 0;
    while (count < 50) {
        mutex.lock();
        while (q.isEmpty()) {
            cond.wait(mutex);
        }
        let val = q.dequeue() as int;
        total.add(val);
        count++;
        mutex.unlock();
    }
}

function main(): void {
    print("--- Threading Tests Start ---");

    // 1. Basic Thread Join
    let resultAtom = new Atomic(0);
    let t1 = new Thread(test_basic_thread, [resultAtom as any]);
    t1.join();
    assert_eq_int(42, resultAtom.load(), "Thread join and atomic store");

    // 2. Mutex Protection
    let mutex = new Mutex();
    let counter = new Atomic(0);
    let m_args: any[] = [mutex as any, counter as any];
    let t2 = new Thread(test_mutex_contention, m_args);
    let t3 = new Thread(test_mutex_contention, m_args);
    t2.join();
    t3.join();
    assert_eq_int(2000, counter.load(), "Mutex protected counter");

    // 3. Atomic Functions
    let atomicCounter = new Atomic(0);
    let a_args: any[] = [atomicCounter as any];
    let t4 = new Thread(test_atomic_add, a_args);
    let t5 = new Thread(test_atomic_add, a_args);
    t4.join();
    t5.join();
    assert_eq_int(2000, atomicCounter.load(), "Atomic add across threads");

    // 4. Condition Variables & SharedQueue
    let q = new SharedQueue<int>();
    let cv_mutex = new Mutex();
    let cond = new Condition();
    let sum = new Atomic(0);
    let producer_args: any[] = [q as any, cv_mutex as any, cond as any];
    let consumer_args: any[] = [q as any, cv_mutex as any, cond as any, sum as any];
    
    let tp = new Thread(producer, producer_args);
    let tc = new Thread(consumer, consumer_args);
    
    tp.join();
    tc.join();
    
    // Sum of 0..49 is (49 * 50) / 2 = 1225
    assert_eq_int(1225, sum.load(), "Condition variable and SharedQueue synchronization");

    print("--- Threading Tests Complete ---");
}
