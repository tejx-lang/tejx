// Stdlib Misc Tests
// =================
import std:math;
import std:fs;
import std:system; 
import { assert_eq_int, assert_eq_string, assert_true } from "../utils.tx";

function test_extra_arrays() {
    print("--- Extra Array Methods ---");
    let arr = [3, 1, 2];
    arr.sort();
    assert_eq_int(1, arr[0], "sort[0]");
    assert_eq_int(2, arr[1], "sort[1]");
    
    
    assert_true(arr.includes(2), "includes(2)");
}

function test_extra_strings() {
    print("--- Extra String Methods ---");
    let s = "  hello  ";
    assert_eq_string("hello  ", s.trimStart(), "trimStart");
    assert_eq_string("  hello", s.trimEnd(), "trimEnd");
    
    let s2 = "hello world";
    assert_true(s2.includes("world"), "includes");
    assert_eq_int(6, s2.indexOf("world"), "indexOf");
}

function test_stdlib_wrappers() {
    print("--- Stdlib Wrappers (Math/FS/OS) ---");
    // Math wrappers
    assert_eq_int(42, abs(-42), "abs");
    assert_eq_int(1024, pow(2, 10), "pow");
    assert_eq_int(5, sqrt(25), "sqrt");
    
    // FS Wrappers (if globals exist, otherwise via fs module)
    // The original file used `exists(fname)`, `remove(fname)`, `write(fname, ...)`
    // Assuming they are imported from std:fs or global.
    // Let's use fs.* for safety unless we know they are global.
    // If features_stdlib_std.tx worked, and it imported std:fs, maybe they are exported top-level?
    // Let's assume fs.* for now to be safe, or just skip if redundant with io.tx.
    
    // OS
    let argv = args();
    assert_eq_int(1, argv.length(), "args count");
}

function main() {
    print("=== STDLIB MISC START ===");
    test_extra_arrays();
    test_extra_strings();
    test_stdlib_wrappers();
    print("=== STDLIB MISC COMPLETE ===");
}
