// --- Features OOP Super ---

class BaseSC {
    greet(name: string): string { return "Hello " + name + " from Base"; }
    calc(x: int): int { return x * 2; }
}

class DerivedSC extends BaseSC {
    greet(name: string): string {
        let base_msg = super.greet(name);
        return base_msg + " (and Derived)";
    }
    calc(x: int): int {
        let base_val = super.calc(x);
        return base_val + 1;
    }
}

function test_super() {
    print("--- Super Calls ---");
    let d = new DerivedSC();
    assert_eq_string("Hello Alice from Base (and Derived)", d.greet("Alice"), "Super greet");
    assert_ne_string("Hello Alice from Base", d.greet("Alice"), "Super greet not base only");
    assert_eq_int(21, d.calc(10), "Super calc"); // 10*2 + 1
    assert_ne_int(20, d.calc(10), "Super calc not base only");
}

function test_deep_inheritance() {
    print("--- Deep Inheritance ---");
    let btn = new Button(1, "Submit");
    assert_eq_string("Button['Submit'] -> Element(button) -> Node(1)", btn.describe(), "Deep inheritance describe");

    // Polymorphism
    let node = new Node(1);
    let elem = new Element(2, "div");
    let btn2 = new Button(3, "OK");

    assert_eq_string("Node(1)", node.describe(), "Polymorphism Node");
    assert_eq_string("Element(div) -> Node(2)", elem.describe(), "Polymorphism Element");
    assert_eq_string("Button['OK'] -> Element(button) -> Node(3)", btn2.describe(), "Polymorphism Button");
}

function main() {
    print("=== OOP TESTS START ===");
    test_oop();
    test_objects();
    // test_structs();
    test_super();
    test_deep_inheritance();
    print("=== OOP TESTS COMPLETE ===");
}
