// OOP Tests (Consolidated)
// ========================
import { assert_eq_int, assert_eq_string, assert_true, assert_false, assert_ne_int, assert_ne_string } from "../utils.tx";

// --- Interfaces & Classes ---

interface Greeter {
    greet(name: string): void;
}

class Entity {
    id: int32;
    constructor(id: int32) {
        this.id = id;
    }
}

class Robot extends Entity {
    model: string;
    constructor(id: int32, model: string) {
        super(id); 
        this.id = id;
        this.model = model;
    }
    identify(): string {
        return this.model;
    }
    greet(name: string): string {
        return "Hello " + name;
    }
    status(): string {
        return "Operational";
    }
}

class Point {
    x: int32;
    y: int32;
    constructor(x: int32, y: int32) {
        this.x = x;
        this.y = y;
    }
}

class BankAccount {
    private balance: int32 = 0;
    public owner: string;
    static bankName: string = "MyBank";

    constructor(owner: string, initialBalance: int32) {
        this.owner = owner;
        this.balance = initialBalance;
    }

    public deposit(amount: int32): void {
        this.balance += amount;
    }

    public getBalance(): int32 {
        return this.balance;
    }
    
    static getBankName(): string {
        return BankAccount.bankName;
    }
}

class Person {
    _name: string = "";
    _age: int32 = 0;
    
    constructor(name: string, age: int32) {
        this._name = name;
        this._age = age;
    }
    
    getName(): string { return this._name; }
    setName(value: string): void { this._name = value; }
    
    getAge(): int32 { return this._age; }
    setAge(value: int32): void { if (value >= 0) this._age = value; }
    
    getInfo(): string { return this._name + " is " + this._age + " years old"; }
}

class Animal {
    name: string;
    constructor(n: string) { this.name = n; }
    speak(): string { return "noise"; }
}

class Dog extends Animal {
    breed: string;
    constructor(n: string) {
        super(n);
        this.name = n;
        this.breed = "Unknown";
    }
    speak(): string { return "bark"; }
}

abstract class Shape {
    protected name: string;
    constructor() { this.name = "Unknown Shape"; }
    abstract area(): int32;
    // describe(): string { return this.name; }
}

class Circle extends Shape {
    private radius: int32;
    constructor(r: int32) {
        super();
        this.name = "Circle"; 
        this.radius = r;
    }
    area(): int32 {
        // approx
        return 3 * this.radius * this.radius; 
    }
}

// --- Deep Inheritance (from modern_capabilities.tx) ---

class Node {
    id: int32;
    constructor(id: int32) { this.id = id; }
    describe(): string { return "Node(" + this.id + ")"; }
}

class Element extends Node {
    tagName: string;
    constructor(id: int32, tagName: string) {
        super(id);
        this.tagName = tagName;
    }
    describe(): string { return "Element(" + this.tagName + ") -> " + super.describe(); }
}

class Button extends Element {
    label: string;
    constructor(id: int32, label: string) {
        super(id, "button");
        this.label = label;
    }
    describe(): string { return "Button['" + this.label + "'] -> " + super.describe(); }
}

function test_oop() {
    print("--- OOP Features ---");
    let r = new Robot(101, "T-800");
    assert_eq_string("T-800", r.identify(), "Robot identify");
    assert_ne_string("", r.identify(), "Robot identify not empty");
    assert_eq_string("Hello Human", r.greet("Human"), "Robot extension greet");
    assert_ne_string("Hello Human", r.greet("Bot"), "Robot greet different input");
    assert_eq_string("Operational", r.status(), "Robot extension status");
    assert_ne_string("", r.status(), "Robot status not empty");

    // Memory block
    {
        let p = new Point(10, 20);
        assert_eq_int(10, p.x, "Point x");
    }

    // Static & Encapsulation

    assert_eq_string("MyBank", BankAccount.getBankName(), "Static method");
    let acc = new BankAccount("Alice", 100);
    acc.deposit(50);
    assert_eq_int(150, acc.getBalance(), "Encapsulation deposit");
    assert_ne_int(100, acc.getBalance(), "Balance not original");
    assert_ne_int(0, acc.getBalance(), "Balance not zero");

    // Getter/Setter
    let p2 = new Person("Alice", 30);
    assert_eq_string("Alice", p2.getName(), "Getter name");
    p2.setName("Bob");
    assert_eq_string("Bob", p2.getName(), "Setter name");
    assert_eq_string("Bob is 30 years old", p2.getInfo(), "Computed getter");

    // Inheritance & Abstract
    let d = new Dog("Buddy");
    assert_eq_string("bark", d.speak(), "Override method");
    assert_ne_string("noise", d.speak(), "Override not base");
    assert_true(d instanceof Dog, "instanceof Dog");
    assert_true(d instanceof Animal, "instanceof Animal");

    let c = new Circle(2);
    assert_eq_int(12, c.area(), "Abstract impl area"); // 3 * 2 * 2
    assert_ne_int(0, c.area(), "Abstract area not zero");
}

// --- Features Objects ---

function test_objects() {
    print("--- Objects (Structural) ---");
    let user = {
        name: "TejX",
        age: 1,
        active: true,
        address: { city: "Metropolis", zip: 12345 }
    };
    assert_eq_string("TejX", user.name, "Object property");
    assert_ne_string("", user.name, "Object name not empty");
    assert_eq_string("Metropolis", user.address.city, "Nested object property");
    assert_ne_string("", user.address.city, "Nested city not empty");

    // Bracket notation
    assert_eq_string("TejX", "" + user["name"], "Bracket notation");

    // Array inside object
    let o = { list: [1, 2, 3] };
    assert_eq_int(2, o.list[1], "Array inside object");

    // Mixed complex
    let config = {
        servers: [ { port: 80 }, { port: 8080 } ]
    };
    assert_eq_int(8080, config.servers[1].port, "Complex object mixing");
}

