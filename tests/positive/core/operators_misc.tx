// Operators & Typeof Tests
// ========================
import { assert_eq_string, assert_eq_int } from "../utils.tx";

function main() {
    print("=== OPERATORS MISC START ===");
    
    // Typeof
    let i = 10;
    let s = "str";
    let c = true;
    
    // Note: assertions depend on implementation return values
    // Using string matching if possible, else print
    assert_eq_string(typeof(i), "int", "typeof(i) should be int");
    assert_eq_string(typeof(s), "string", "typeof(s) should be string");
    assert_eq_string(typeof(c), "bool", "typeof(c) should be bool");
    

    // Bitwise (from bitwise.tx)
    print("--- Bitwise ---");
    let a = 5;  // 0101
    let b = 3;  // 0011
    assert_eq_int(a & b, 1, "a & b should be 1");
    assert_eq_int(a | b, 7, "a | b should be 7");
    assert_eq_int(a ^ b, 6, "a ^ b should be 6");
    assert_eq_int(a << 1, 10, "a << 1 should be 10");
    
    print("=== OPERATORS MISC COMPLETE ===");
}
