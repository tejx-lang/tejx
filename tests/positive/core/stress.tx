// Stress Tests
// ============
import std:time;
import { assert_eq_int, assert_true } from "../utils.tx";

function ackermann(m: int32, n: int32): int32 {
    if (m == 0) return n + 1;
    else if (n == 0) return ackermann(m - 1, 1);
    else return ackermann(m - 1, ackermann(m, n - 1));
}

class Counter {
    state: int32;
    constructor(start: int32) { this.state = start; }
    increment(): int32 { this.state = this.state + 1; return this.state; }
    getValue(): int32 { return this.state; }
}

function makeCounter(start: int32): Counter { return new Counter(start); }

function main() {
    print("=== STRESS TESTS START ===");
    
    // Recursion
    assert_eq_int(7, ackermann(2, 2), "Ackermann(2, 2)");
    
    // Closures/Objects
    let counter = makeCounter(10);
    counter.increment(); // 11
    counter.increment(); // 12
    assert_eq_int(12, counter.getValue(), "Counter class state");
    
    // Matrix Multiplication
    let matrix = [[1, 2, 3], [4, 5, 6], [7, 8, 9]];
    let v = [1, 2, 3];
    let res = [0, 0, 0];
    
    for (let r = 0; r < 3; r++) {
        let row = matrix[r];
        let sum = 0;
        for (let c = 0; c < 3; c++) {
            sum = sum + (row[c] * v[c]);
        }
        res[r] = sum;
    }
    assert_eq_int(14, res[0], "Matrix row 0");
    assert_eq_int(32, res[1], "Matrix row 1");
    assert_eq_int(50, res[2], "Matrix row 2");
    
    // Loop Performance
    let sum = 0;
    let limit = 10000; // reduced test size for CI speed
    let start = time.now();
    for (let i = 1; i <= limit; i++) {
        sum = sum + i;
    }
    print("Loop time: ", time.now() - start, "ms");
    assert_true(sum > 0, "Loop sum positive");

    print("=== STRESS TESTS COMPLETE ===");
}
