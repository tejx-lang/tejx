// Error Handling Tests
// ====================
import { assert_eq_int, assert_eq_string, assert_true } from "../utils.tx";

class CustomError extends Error {
    code: int32;
    constructor(m: string, c: int32) {
        super(m, c);
        this.code = c;
    }
}

function process(x: int32): int32 {
    if (x < 0) {
        throw new CustomError("Negative input", 400);
    }
    if (x == 0) {
        throw new Error("Zero is not allowed");
    }
    return 100 / x;
}

function test_nested_try_catch() {
    print("--- Nested Try/Catch ---");
    let point = 0;
    try {
        point += 1; // 1
        try {
            point += 1; // 2
            process(-1);
        } catch (innerErr) {
            // Catch CustomError
            assert_eq_string("Negative input", innerErr.getMessage(), "Inner catch message");
            point += 1; // 3
            throw innerErr;
        } finally {
            point += 1; // 4
        }
    } catch (err) {
        // Outer catch rethrow
        assert_eq_string("Negative input", err.getMessage(), "Outer catch message");
        point += 1; // 5
    } finally {
        point += 1; // 6
    }
    assert_eq_int(6, point, "Execution flow checkpoints");
}

function test_basic_throws() {
    print("--- Basic Throws ---");
    // Base Error throw
    try {
        process(0);
        assert_true(false, "Should have thrown Error");
    } catch (e) {
        assert_eq_string("Error", e.getName(), "Caught Error exposes clean type name");
        assert_eq_string("Error: Zero is not allowed", e.toString(), "Caught Error toString stays readable");
        assert_eq_string("Zero is not allowed", e.getMessage(), "Caught Error message");
    }
    
    // CustomError throw
    try {
        process(-5);
        assert_true(false, "Should have thrown CustomError");
    } catch (e) {
        let custom = e as CustomError;
        assert_eq_string("CustomError", custom.getName(), "Caught CustomError exposes clean type name");
        assert_eq_string("CustomError: Negative input (code: 400)", custom.toString(), "Caught CustomError toString includes code");
        assert_eq_int(400, custom.code, "Caught CustomError code");
        assert_eq_string("Negative input", custom.getMessage(), "Caught CustomError message");
    }
}

function test_loop_error() {
    print("--- Error in Loop ---");
    let caught_zero = false;
    for (let i = -2; i <= 2; i = i + 1) {
        try {
            if (i == 0) throw new Error("Zero!");
            let res = 10/i;
        } catch (e) {
            if (e.getMessage() == "Zero!") caught_zero = true;
        }
    }
    assert_true(caught_zero, "Caught error inside loop");
}

function test_base_error_throw() {
    print("--- Base Error Throw ---");
    try {
        throw new Error("error");
    } catch (e) {
        print(e);
        let frames = e.getStackFrames();
        assert_eq_string("error", e.message, "Caught Error exposes message field");
        assert_eq_string("Error", e.getName(), "Caught Error getName works");
        assert_eq_string("Error: error", e.toString(), "Caught Error toString stays compact");
        assert_eq_string("error", e.getMessage(), "Caught Error message");
        assert_true(e.stack.length() > 0, "Caught Error exposes stack field");
        assert_eq_string(e.stack, e.getStack(), "Caught Error stack getter matches field");
        assert_true(frames.length() > 0, "Caught Error exposes parsed stack frames");
        assert_true(frames[0].indexOf("at test_base_error_throw") >= 0, "Caught Error first stack frame is clean");
        assert_true(e.stack.indexOf("at test_base_error_throw") >= 0, "Caught Error stack keeps throw site");
    }
}

function test_runtime_error_extracts_message_and_stack() {
    print("--- Runtime Error Extraction ---");
    try {
        let denom = 0;
        let _ = 10 / denom;
        assert_true(false, "Should have thrown RuntimeError");
    } catch (e) {
        let frames = e.getStackFrames();
        assert_true(e instanceof RuntimeError, "Runtime failures normalize to RuntimeError");
        assert_eq_string("RuntimeError", e.getName(), "RuntimeError exposes clean type name");
        assert_eq_string("RuntimeError: Division by zero while evaluating 10 / 0", e.toString(), "RuntimeError toString stays readable");
        assert_eq_string("Division by zero while evaluating 10 / 0", e.message, "RuntimeError exposes message");
        assert_eq_string(e.message, e.getMessage(), "RuntimeError getter matches field");
        assert_true(e.stack.length() > 0, "RuntimeError exposes stack field");
        assert_eq_string(e.stack, e.getStack(), "RuntimeError stack getter matches field");
        assert_true(frames.length() > 0, "RuntimeError exposes parsed stack frames");
        assert_true(frames[0].indexOf("at test_runtime_error_extracts_message_and_stack") >= 0, "RuntimeError first stack frame is clean");
        assert_true(e.stack.indexOf("at test_runtime_error_extracts_message_and_stack") >= 0, "RuntimeError stack keeps crash site");
    }
}

function main() {
    print("=== ERROR TESTS START ===");
    test_basic_throws();
    test_nested_try_catch();
    test_loop_error();
    test_base_error_throw();
    test_runtime_error_extracts_message_and_stack();
    test_validation();
    print("=== ERROR TESTS COMPLETE ===");
}

// --- Validation Logic (from modern_capabilities.tx) ---

class ValidationResult {
    isValid: bool;
    error: string;
    constructor(valid: bool, err: string) {
        this.isValid = valid;
        this.error = err;
    }
}

function validate(input: string): ValidationResult {
    if (input.length() == 0) {
        return new ValidationResult(false, "Empty string");
    }
    if (input == "error") {
        return new ValidationResult(false, "Invalid keyword");
    }
    return new ValidationResult(true, "");
}

function test_validation() {
    print("--- Validation Tests ---");
    let r1 = validate("hello");
    assert_true(r1.isValid, "Valid input");
    
    let r2 = validate("");
    assert_true(!r2.isValid, "Empty input not valid");
    assert_eq_string("Empty string", r2.error, "Empty input error msg");
    
    let r3 = validate("error");
    assert_true(!r3.isValid, "Error keyword not valid");
    assert_eq_string("Invalid keyword", r3.error, "Error keyword error msg");
}
