// Error Handling Tests
// ====================
import { assert_eq_int, assert_eq_string, assert_true } from "../utils.tx";

class CustomError extends Error {
    code: int32;
    constructor(m: string, c: int32) {
        super(m);
        this.code = c;
    }
}

function process(x: int32): int32 {
    if (x < 0) {
        throw new CustomError("Negative input", 400);
    }
    if (x == 0) {
        throw "Zero is not allowed";
    }
    return 100 / x;
}

function test_nested_try_catch() {
    print("--- Nested Try/Catch ---");
    let point = 0;
    try {
        point += 1; // 1
        try {
            point += 1; // 2
            process(-1);
        } catch (innerErr) {
             // Catch CustomError
             assert_eq_string("Negative input", innerErr.message, "Inner catch message");
             point += 1; // 3
             throw innerErr;
        } finally {
            point += 1; // 4
        }
    } catch (err) {
        // Outer catch rethrow
        assert_eq_string("Negative input", err.message, "Outer catch message");
        point += 1; // 5
    } finally {
        point += 1; // 6
    }
    assert_eq_int(6, point, "Execution flow checkpoints");
}

function test_basic_throws() {
    print("--- Basic Throws ---");
    // String throw
    try {
        process(0);
        assert_true(false, "Should have thrown string");
    } catch (e) {
        assert_eq_string("Zero is not allowed", e, "Caught string exception");
    }

    // Object throw
    try {
        process(-5);
        assert_true(false, "Should have thrown object");
    } catch (e) {
        assert_eq_int(400, e.code, "Caught CustomError code");
        assert_eq_string("Negative input", e.message, "Caught CustomError message");
        // Check toString if available
        // assert_eq_string("Error: Negative input", e.toString(), "Error toString"); 
    }
}

function test_loop_error() {
    print("--- Error in Loop ---");
    let caught_zero = false;
    for (let i = -2; i <= 2; i = i + 1) {
        try {
            if (i == 0) throw "Zero!";
            let res = 10/i;
        } catch (e) {
            if (e == "Zero!") caught_zero = true;
        }
    }
    assert_true(caught_zero, "Caught error inside loop");
}

function main() {
    print("=== ERROR TESTS START ===");
    test_basic_throws();
    test_nested_try_catch();
    test_loop_error();
    test_validation();
    print("=== ERROR TESTS COMPLETE ===");
}

// --- Validation Logic (from modern_capabilities.tx) ---

class ValidationResult {
    isValid: boolean;
    error: string;
    constructor(valid: boolean, err: string) {
        this.isValid = valid;
        this.error = err;
    }
}

function validate(input: string): ValidationResult {
    if (input.length() == 0) {
        return new ValidationResult(false, "Empty string");
    }
    if (input == "error") {
        return new ValidationResult(false, "Invalid keyword");
    }
    return new ValidationResult(true, "");
}

function test_validation() {
    print("--- Validation Tests ---");
    let r1 = validate("hello");
    assert_true(r1.isValid, "Valid input");

    let r2 = validate("");
    assert_true(!r2.isValid, "Empty input not valid");
    assert_eq_string("Empty string", r2.error, "Empty input error msg");

    let r3 = validate("error");
    assert_true(!r3.isValid, "Error keyword not valid");
    assert_eq_string("Invalid keyword", r3.error, "Error keyword error msg");
}
