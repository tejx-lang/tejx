import { assert_eq_int, assert_eq_string } from "../utils.tx";
import { Map, Set } from "std:collections";

// Regression tests from issue_test.tx

// 1. Array of objects type
type Point = { x: int, y: int }[];
let pts: Point = [{x: 1, y: 2}];

// 2. Exact object typing vs structural typing
type SinglePoint = { x: int, y: int };

// 3. Array push type mismatch
let b_list: SinglePoint[] = [];

// 5. Array literal type inference
let d_val = [4];

// 6. Object spread and Array spread
let obj = { x: 1 };
let obj2 = { ...obj };

let arr1 = [4, 5];
let arr2 = [...arr1];

// --- Documentation Verification (from doc_verify_valid.tx) ---

class Box<T> {
    value: T;
    constructor(val: T) {
        this.value = val;
    }
    unwrap(): T {
        return this.value;
    }
}

function identity<T>(item: T): T {
    return item;
}

function greet(name: string, age: int): string {
    return "Hello " + name;
}

function test_doc_verification() {
    print("--- Documentation Verification ---");
    let scores: int[] = [1, 2, 3];
    let nickname: string | None = "Ace";
    nickname = None;

    let cache = new Map<string, int>();
    cache.set("Alice", 95);
    let aliceScore = cache.get("Alice");

    let names = new Set<string>();
    names.add("Bob");

    let x: int = 10;
    let y = x;
    let z = x + y;

    let intBox = new Box<int>(42);
    let payload = intBox.unwrap();

    let text = identity("Hello");
    let msg = greet("Alice", 25);

    print("All verification tests passed!");
    assert_eq_int(20, z, "Copy semantics sum");
    assert_eq_int(42, payload, "Generic Box unwrap");
    assert_eq_string("Hello", text, "Generic identity");
}

function main() {
    print("=== ISSUES TESTS START ===");
    
    assert_eq_int(1, pts[0].x, "Array of objects");
    
    b_list.push({x: 2, y: 4});
    assert_eq_int(2, b_list[0].x, "Array push object");

    assert_eq_int(4, d_val[0], "Array literal inference");

    assert_eq_int(1, obj2.x, "Object spread");

    arr2[0] = 3;
    assert_eq_int(3, arr2[0], "Array spread target");
    assert_eq_int(4, arr1[0], "Array spread source original");

    test_doc_verification();

    print("=== ISSUES TESTS COMPLETE ===");
}
