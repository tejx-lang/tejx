
// Function Ownership - Positive Test
// ==================================

class Container {
    id: int32;
    constructor(id: int32) { this.id = id; }
}

function takeObject(c: Container) {
    print("Inside takeObject, Container ID:", c.id);
    // 'c' is owned by takeObject. It will be freed at end of function.
}

function takeArray(arr: int32[]) {
    print("Inside takeArray, Length:", arr.length);
    if (arr.length > 0) {
        print("First Element:", arr[0]);
    }
}

function takeString(s: string) {
    print("Inside takeString:", s);
}

function takePrimitive(val: int32) {
    print("Inside takePrimitive:", val);
}

function returnOwnership(c: Container): Container {
    print("Passing through object:", c.id);
    return c;
}

function main() {
    print("--- Function Ownership Test ---");

    // 1. Object Ownership Transfer
    print("\n1. Object Move:");
    let c1 = new Container(100);
    takeObject(c1); 
    // c1 is Moved. Accessing c1 here would be error.
    print("Container 1 moved successfully.");

    // 2. Array Ownership Transfer
    print("\n2. Array Move:");
    let arr = [1, 2, 3];
    takeArray(arr);
    // arr is Moved.
    print("Array moved successfully.");

    // 3. String Ownership Transfer
    print("\n3. String Move:");
    let s = "Hello Ownership";
    takeString(s);
    // s is Moved
    print("String moved successfully.");

    // 4. Primitive Copy (Not Move)
    print("\n4. Primitive Copy:");
    let num = 42;
    takePrimitive(num);
    print("Primitive still accessible:", num); // Should be allowed

    // 5. Returning Ownership
    print("\n5. Return Ownership:");
    let c2 = new Container(200);
    // Move c2 into function, get it back in c3
    let c3 = returnOwnership(c2); 
    print("Got container back in c3:", c3.id);
    // c2 is Moved. c3 is Live.

    print("\n--- End Test ---");
}
