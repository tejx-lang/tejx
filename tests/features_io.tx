let path = "test_file.txt";
let content = "Hello from TejXFS!";

console.log("--- File I/O Test ---");
console.log("Writing to ", path);
fs.writeFile(path, content);

console.log("Reading from ", path);
let readBack = fs.readFile(path);
console.log("Content: ", readBack);

if (readBack == content) {
    console.log("SUCCESS: Content matches!");
} else {
    console.log("FAILURE: Content mismatch.");
}

// FileSystem++ Verification

// Clean up first
if (fs.exists("test_fs_dir")) {
    console.log("Cleaning up old dir...");
    fs.remove("test_fs_dir");
}

console.log("Checking if dir exists (should be false): ", fs.exists("test_fs_dir"));

console.log("Creating directory...");
fs.mkdir("test_fs_dir");
console.log("Checking if dir exists (should be true): ", fs.exists("test_fs_dir"));

let filePath = "test_fs_dir/hello.txt";
console.log("Writing file...");
fs.writeFile(filePath, "Hello World from FS++");

console.log("Checking file exists: ", fs.exists(filePath));
console.log("Reading file: ", fs.readFile(filePath));

console.log("Removing directory (recursive)...");
fs.remove("test_fs_dir");
console.log("Checking if dir exists (should be false): ", fs.exists("test_fs_dir"));
