let path = "test_file.txt";
let content = "Hello from TejXFS!";

print("--- File I/O Test ---");
print("Writing to ", path);
fs.writeFile(path, content);

print("Reading from ", path);
let readBack = fs.readFile(path);
print("Content: ", readBack);

if (readBack == content) {
    print("SUCCESS: Content matches!");
} else {
    print("FAILURE: Content mismatch.");
}

// FileSystem++ Verification

// Clean up first
if (fs.exists("test_fs_dir")) {
    print("Cleaning up old dir...");
    fs.remove("test_fs_dir");
}

print("Checking if dir exists (should be false): ", fs.exists("test_fs_dir"));

print("Creating directory...");
fs.mkdir("test_fs_dir");
print("Checking if dir exists (should be true): ", fs.exists("test_fs_dir"));

let filePath = "test_fs_dir/hello.txt";
print("Writing file...");
fs.writeFile(filePath, "Hello World from FS++");

print("Checking file exists: ", fs.exists(filePath));
print("Reading file: ", fs.readFile(filePath));

print("Removing directory (recursive)...");
fs.remove("test_fs_dir");
print("Checking if dir exists (should be false): ", fs.exists("test_fs_dir"));

// Cleanup the first test file
fs.remove("test_file.txt");
