// Array Features: Creation, Access, Spread, Destructuring
// ========================================================

print("--- Array Creation & Access ---");
let numbers: number[] = [10, 20, 30, 40, 50];
print("Original Array: Expected: [10, 20, 30, 40, 50], Actual: ", numbers); 
print("First Element: Expected: 10, Actual: ", numbers[0]);
print("Length: Expected: 5, Actual: ", numbers.length);

// Mutation
numbers[1] = 99;
print("Modified Element at 1: Expected: 99, Actual: ", numbers[1]);

// Push
numbers.push(60);
print("New Length after push: Expected: 6, Actual: ", numbers.length);

// Spread Operator
print("\n--- Spread Operator ---");
let moreNumbers = [0, ...numbers, 70];
print("Combined Array Length: Expected: 8, Actual: ", moreNumbers.length); 

// Array Destructuring
print("\n--- Array Destructuring ---");
let point: number[] = [100, 200];
let [x, y] = point;
print("Destructured X: Expected: 100, Actual: ", x);
print("Destructured Y: Expected: 200, Actual: ", y);

// Rest Pattern in Destructuring
let [head, ...tail] = [1, 2, 3, 4];
print("Head: Expected: 1, Actual: ", head); 
print("Tail: Expected: [2, 3, 4], Actual: ", tail); 

let nums = [1, 2, 3, 4, 5];

print("Original Numbers: Expected: 1-5");
nums.forEach(x => print("Value: ", x));

let doubled = nums.map(x => x * 2);
print("Doubled Numbers: Expected: 2, 4, 6, 8, 10");
doubled.forEach(x => print("Value: ", x));

let evens = nums.filter(x => x % 2 == 0);
print("Even Numbers: Expected: 2, 4");
evens.forEach(x => print("Value: ", x));

// Array Utilities Test
print("Testing array utilities...");

let arrUtil = [1, 2, 3];
print("Initial array: Expected: 1, 2, 3, Actual: ", arrUtil.join(", "));

// push and pop
arrUtil.push(4);
print("After push(4): Expected: 1, 2, 3, 4, Actual: ", arrUtil.join(", "));

let popped = arrUtil.pop();
print("Popped: Expected: 4, Actual: ", popped);
print("After pop: Expected: 1, 2, 3, Actual: ", arrUtil.join(", "));

// shift and unshift
arrUtil.unshift(0);
print("After unshift(0): Expected: 0, 1, 2, 3, Actual: ", arrUtil.join(", "));

let shifted = arrUtil.shift();
print("Shifted: Expected: 0, Actual: ", shifted);
print("After shift: Expected: 1, 2, 3, Actual: ", arrUtil.join(", "));

// concat
let arrSpread2 = [4, 5, 6];
let merged = arrUtil.concat(arrSpread2);
print("Concatenated: Expected: 1, 2, 3, 4, 5, 6, Actual: ", merged.join(", "));

// indexOf
print("indexOf(2): Expected: 1, Actual: ", arrUtil.indexOf(2));
print("indexOf(99): Expected: -1, Actual: ", arrUtil.indexOf(99));

// join with custom separator
print("Joined with ' - ': Expected: 1 - 2 - 3, Actual: ", arrUtil.join(" - "));

print("Array utilities test complete!");


// Object Destructuring
let {name, age} = {name: "TejX", age: 1};
print("Destructured Name: Expected: TejX, Actual: ", name);
print("Destructured Age: Expected: 1, Actual: ", age);

// Custom target names
let {name: n, age: g} = {name: "Antigravity", age: 5};
print("n (Antigravity): Expected: Antigravity, Actual: ", n);
print("g (5): Expected: 5, Actual: ", g);

// Nested Destructuring
let [x2, {y: y2}] = [10, {y: 20}];
print("x2 (10): Expected: 10, Actual: ", x2);
print("y2 (20): Expected: 20, Actual: ", y2);

// Deeper Nesting
let {user: {profile: {firstName}}} = {user: {profile: {firstName: "John"}}};
print("First Name: Expected: John, Actual: ", firstName);

// Spread Operator Test
print("Testing spread operator...");

let arr1 = [1, 2, 3];
let arr2Spread = [4, 5, 6];

// Spread to combine arrays
let combined = [...arr1, ...arr2Spread];
print("Combined: Expected: 1, 2, 3, 4, 5, 6, Actual: ", combined.join(", "));

// Spread with additional elements
let withExtra = [0, ...arr1, 4, 5];
print("With extra: Expected: 0, 1, 2, 3, 4, 5, Actual: ", withExtra.join(", "));

// Spread to copy
let copy = [...arr1];
print("Copy: Expected: 1, 2, 3, Actual: ", copy.join(", "));

print("Spread operator test complete!");

// Rest Arguments Test
function sum(...nums: number[]): number {
    let total = 0;
    for (let i = 0; i < nums.length; i = i + 1) {
        total = total + nums[i];
    }
    return total;
}

print("Sum 1,2,3: Expected: 6, Actual: ", sum(1, 2, 3));
print("Sum 10,20: Expected: 30, Actual: ", sum(10, 20));


// --- NEW: Nested Arrays & Matrix Operations ---
print("\n--- Nested Arrays & Matrix ---");
let matrix = [
    [1, 2, 3],
    [4, 5, 6],
    [7, 8, 9]
];

print("Matrix[1][1]: Expected: 5, Actual: ", matrix[1][1]);

let diagSum = 0;
for(let i=0; i<3; i++) {
    diagSum += matrix[i][i];
}
print("Diagonal Sum: Expected: 15 (1+5+9), Actual: ", diagSum);

// Flattening
let flat: number[] = [];
matrix.forEach(row => {
    row.forEach(val => flat.push(val));
});
print("Flattened: Expected: 1..9, Actual: ", flat.join(","));

print("=== Arrays Test Complete ===");
