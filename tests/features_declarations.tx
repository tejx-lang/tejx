// Declarations: Variables, Functions, Lambdas
// ============================================

console.log("--- Variables ---");
// Implicit type
let x = 10; 
// Explicit type
let y: number = 20;
// Constant
const PI: number = 3.14159;
// String
let name: string = "NovaJs";
// Boolean
let isAwesome: boolean = true;
// Any
let dynamic: any = "I can handle anything";
console.log(dynamic);
dynamic = 100;
console.log(dynamic);


console.log("\n--- Functions ---");

// Standard Function
function add(a: number, b: number): number {
    return a + b;
}
console.log("Add(10, 20): ", add(10, 20));


console.log("\n--- Lambdas (Arrow Functions) ---");

// Single expression body
const multiply = (a: number, b: number) => a * b;
console.log("Multiply(5, 5): ", multiply(5, 5));

// Block body
const complexCalc = (val: number) => {
    let temp = val * 2;
    return temp + 1;
};
console.log("ComplexCalc(10): ", complexCalc(10));

// Passing lambda as argument
function process(val: number, op: (n: number) => number): number {
    return op(val);
}

let squared = process(4, (n) => n * n);
console.log("Squared(4): ", squared);
// Const Keyword Test

console.log("Testing const keyword...");

const PI2 = 3.14159;
console.log("PI2 = ", PI2);

const MESSAGE = "Hello, TejX!";
console.log("MESSAGE = ", MESSAGE);

// Const with typed array
const numbers: number[] = [1, 2, 3];
console.log("Const array: ", numbers.join(", "));

// Note: const prevents reassignment, not mutation
// numbers.push(4); // This would still work in JS, and here too

console.log("Const test complete!");
const lambdaAdd = (x: number, y: number) => {
    return x + y;
};
console.log("Add(5,3):");
console.log(lambdaAdd(5, 3));

const square = (x: number) => x * x;
console.log("Square(4):");
console.log(square(4));

const lambdaGreet = () => {
    console.log("Hello Lambda!");
};
lambdaGreet();
function greetUser(name: string = "Guest") {
    console.log("Hello, ", name);
}

function power(base: number, exp: number = 2) {
    console.log(base, "^", exp, " = ", Math.pow(base, exp));
}

console.log("--- Default Args Test ---");
greetUser();
greetUser("TejX");
power(5);
power(2, 3);
// typeof Operator Test

let nVal = 42;
let sVal = "hello";
let bVal = true;
let objVal = { x: 1 };
let arrVal = [1, 2, 3];

console.log("Testing typeof operator...");

console.log("typeof 42: ", (typeof nVal));
console.log("typeof 'hello': ", (typeof sVal));
console.log("typeof true: ", (typeof bVal));
console.log("typeof {x:1}: ", (typeof objVal));
console.log("typeof [1,2,3]: ", (typeof arrVal));

function testFunc() { return 1; }
// Function types are currently tricky in our C++ mapping, 
// let's see what typeof says for an identifier that is a function.
// For now, it will likely be an error or "undefined" if not specifically handled.

// Verification with conditionals
if (typeof nVal === "number") {
    console.log("Verified: n is a number");
}

if (typeof sVal === "string") {
    console.log("Verified: s is a string");
}

console.log("typeof operator test complete!");
