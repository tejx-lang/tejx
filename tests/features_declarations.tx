// Declarations: Variables, Functions, Lambdas
// ============================================

print("--- Variables ---");
// Implicit type
let x = 10; 
// Explicit type
let y: number = 20;
// Constant
const PI: number = 3.14159;
// String
let name: string = "NovaJs";
// Boolean
let isAwesome: boolean = true;
// Any
let dynamic: any = "I can handle anything";
print("Any (String): Expected: I can handle anything, Actual: ", dynamic);
dynamic = 100;
print("Any (Number): Expected: 100, Actual: ", dynamic);


print("\n--- Functions ---");

// Standard Function
function add(a: number, b: number): number {
    return a + b;
}
print("Add(10, 20): Expected: 30, Actual: ", add(10, 20));


print("\n--- Lambdas (Arrow Functions) ---");

// Single expression body
const multiply = (a: number, b: number) => a * b;
print("Multiply(5, 5): Expected: 25, Actual: ", multiply(5, 5));

// Block body
const complexCalc = (val: number) => {
    let temp = val * 2;
    return temp + 1;
};
print("ComplexCalc(10): Expected: 21, Actual: ", complexCalc(10));

// Passing lambda as argument
function process(val: number, op: (n: number) => number): number {
    return op(val);
}

let squared = process(4, (n) => n * n);
print("Squared(4): Expected: 16, Actual: ", squared);
// Const Keyword Test

print("Testing const keyword...");

const PI2 = 3.14159;
print("PI2: Expected: 3.14159, Actual: ", PI2);

const MESSAGE = "Hello, TejX!";
print("MESSAGE: Expected: Hello, TejX!, Actual: ", MESSAGE);

// Const with typed array
const numbers: number[] = [1, 2, 3];
print("Const array: Expected: 1, 2, 3, Actual: ", numbers.join(", "));

// Note: const prevents reassignment, not mutation
// numbers.push(4); // This would still work in JS, and here too

print("Const test complete!");
const lambdaAdd = (x: number, y: number) => {
    return x + y;
};
print("lambdaAdd(5,3): Expected: 8, Actual: ", lambdaAdd(5, 3));

const square = (x: number) => x * x;
print("square(4): Expected: 16, Actual: ", square(4));

const lambdaGreet = () => {
    print("lambdaGreet: Expected: Hello Lambda!, Actual: Hello Lambda!");
};
lambdaGreet();
function greetUser(name: string = "Guest") {
    print("greetUser(", name, "): Expected: Hello, ", name, ", Actual: Hello, ", name);
}

function power(base: number, exp: number = 2) {
    print(base, "^", exp, ": Expected: ", Math.pow(base, exp), ", Actual: ", Math.pow(base, exp));
}

print("--- Default Args Test ---");
greetUser();
greetUser("TejX");
power(5);
power(2, 3);
// typeof Operator Test

let nVal = 42;
let sVal = "hello";
let bVal = true;
let objVal = { x: 1 };
let arrVal = [1, 2, 3];

print("Testing typeof operator...");

print("typeof 42: Expected: number/42, Actual: ", (typeof nVal));
print("typeof 'hello': Expected: string/hello, Actual: ", (typeof sVal));
print("typeof true: Expected: boolean/true, Actual: ", (typeof bVal));
print("typeof {x:1}: Expected: [Object], Actual: ", (typeof objVal));
print("typeof [1,2,3]: Expected: [1, 2, 3], Actual: ", (typeof arrVal));

function testFunc() { return 1; }
// Function types are currently tricky in our C++ mapping, 
// let's see what typeof says for an identifier that is a function.
// For now, it will likely be an error or "undefined" if not specifically handled.

// Verification with conditionals
if (typeof nVal === "number") {
    print("Verified: n is a number: Expected: logic pass, Actual: logic pass");
}

if (typeof sVal === "string") {
    print("Verified: s is a string: Expected: logic pass, Actual: logic pass");
}

print("typeof operator test complete!");
