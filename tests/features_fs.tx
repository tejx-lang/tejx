
import std:fs;
import std:time;

async function main() {
    print("--- Testing FS Sync ---");
    
    // Cleanup marker
    if (fs.existsSync("done.marker")) {
        fs.unlinkSync("done.marker");
    }
    
    let path = "test_fs_sync.txt";
    
    // Clean up if exists
    if (fs.existsSync(path)) {
        fs.unlinkSync(path);
    }
    
    // Write
    fs.writeFileSync(path, "Hello Sync");
    print("Written file");
    
    // Exists
    assert(fs.existsSync(path));
    print("File exists: true");
    
    // Read
    let content = fs.readFileSync(path);
    print("Read content: " + content);
    assert(content == "Hello Sync");
    
    // Append
    fs.appendFileSync(path, " World");
    content = fs.readFileSync(path);
    print("Appended content: " + content);
    assert(content == "Hello Sync World");
    
    // Unlink
    fs.unlinkSync(path);
    assert(!fs.existsSync(path));
    print("File deleted");
    
    print("\n--- Testing FS Async ---");
    let apath = "test_fs_async.txt";
    
    // Write Async
    await fs.writeFile(apath, "Hello Async");
    print("Async write complete");
    
    // Read Async
    let acontent = await fs.readFile(apath);
    print("Async read content: " + acontent);
    assert(acontent == "Hello Async");
    
    // Cleanup
    fs.unlinkSync(apath);
    print("Async file deleted");
    
    print("\n--- Testing Directory ---");
    let dir = "test_fs_dir";
    if (fs.existsSync(dir)) {
        fs.unlinkSync(dir);
    }
    
    fs.mkdirSync(dir);
    assert(fs.existsSync(dir));
    print("Dir created");
    
    fs.writeFileSync(dir + "/file1.txt", "1");
    fs.writeFileSync(dir + "/file2.txt", "2");
    
    let files = fs.readdirSync(dir);
    print("Dir files: " + files.length); 
    assert(files.length == 2);
    
    fs.unlinkSync(dir);
    assert(!fs.existsSync(dir));
    print("Dir deleted");
    
    print("\nFS Tests Passed!");
}
