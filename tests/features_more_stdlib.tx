
function testArrays() {
    print("--- Extended Array Methods ---");
    let arr = [3, 1, 2];
    arr.sort();
    print("sort: Expected: 1, 2, 3, Actual: ", arr);

    let arr2 = [1, 2, [3, 4]];
    let f = arr2.flat(1);
    print("flat: Expected: 1, 2, 3, 4, Actual: ", f);

    let arr3 = [1, 2];
    let c = arr3.concat([3, 4]);
    print("concat: Expected: 1, 2, 3, 4, Actual: ", c);

    print("includes(2): Expected: true, Actual: ", arr3.includes(2));
    print("includes(5): Expected: false, Actual: ", arr3.includes(5));
}

function testStrings() {
    print("\n--- Extended String Methods ---");
    let s = "  hello  ";
    print("trimStart: '", s.trimStart(), "'");
    print("trimEnd: '", s.trimEnd(), "'");
    
    let s2 = "hello world";
    print("includes('world'): Expected: true, Actual: ", s2.includes("world"));
    print("indexOf('world'): Expected: 6, Actual: ", s2.indexOf("world"));
    
    let sl = s2.slice(0, 5);
    print("slice(0, 5): Expected: hello, Actual: ", sl);
    
    let conc = "a".concat("b");
    print("concat: Expected: ab, Actual: ", conc);
}

testArrays();
testStrings();
