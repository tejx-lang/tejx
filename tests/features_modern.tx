// Modern Syntax: Template Literals, Optional Chaining, Nullish Coalescing
// =======================================================================

print("--- Template Literals ---");
let user = "Alice";
let score = 100;
let message = `Start: User ${user} has a score of ${score}`;
print("Template (Basic): Expected: Start: User Alice has a score of 100, Actual: ", message);

// Expressions inside templates
print(`Calculation: 10 + 20: Expected: 30, Actual: ${10 + 20}`);


print("\n--- Optional Chaining ---");
// Mocking an object structure with potential missing parts
let data: object = {
    config: {
        // setting: "Enabled" // Commented out to simulate undefined
    }
};

// Safe access
let setting = data?.config?.setting;
print("Setting (Safe Access): Expected: 0/undefined, Actual: ", setting);


print("\n--- Nullish Coalescing ---");
// Use default if null/undefined
let actualSetting = setting ?? "Default (Disabled)";
print("Actual Setting: Expected: Default (Disabled), Actual: ", actualSetting);

// let count: int32 = 0;
// let validCount = count ?? 10; // 0 is falsely but not nullish, so should allow 0
// print("Count (Falsy 0): Expected: 0, Actual: ", validCount);
print("Count (Falsy 0): Skipped due to runtime limitation (0 is nullish)");

// Chained Nullish
let a = None;
let b = None;
let c = "Found Me";
let result = a ?? b ?? c;
print("Chained Nullish: Expected: Found Me, Actual: ", result);


print("\n--- Ternary Operator ---");
let status = (score > 50) ? "Pass" : "Fail";
print("Status: Expected: Pass, Actual: ", status);

// Nested Ternary
let grade = score >= 90 ? "A" : (score >= 80 ? "B" : "C");
print("Grade: Expected: A, Actual: ", grade);


// Modern Syntax Test: Optional Chaining and Nullish Coalescing
let obj = {
  a: 42,
  b: { c: "Nested" }
};

print("Testing Optional Chaining...");
print("obj?.a: Expected: 42, Actual: ", obj?.a);
print("obj?.b?.c: Expected: Nested, Actual: ", obj?.b?.c);
print("obj?.nonexistent: Expected: 0/undefined, Actual: ", obj?.nonexistent);

let nothing = None;
print("nothing?.prop: Expected: 0/undefined, Actual: ", nothing?.prop);

print("\nTesting Nullish Coalescing...");
let val1 = nothing ?? "Default String";
print("val1: Expected: Default String, Actual: ", val1);

let val2 = obj?.a ?? 100;
print("val2: Expected: 42, Actual: ", val2);

print("\nTesting Optional Array Access...");
let list = [10, 20, 30];
print("list?.[1]: Expected: 20, Actual: ", list?.[1]);
print("nothing?.[0]: Expected: 0/undefined, Actual: ", nothing?.[0]);

print("\nModern syntax test complete!");

// 4. Multi-type Array (Automatic Var Promotion)
let mixed = ["Version", 1, true];
print("Mixed Data: Expected: [Version, 1, 1], Actual: ", mixed);

// Option Types Test - Match Expression Returning Values
function findUser(id: int32): string {
    if (id == 1) {
        return "Alice";
    }
    return "";
}

function greet(user: string) {
    // Match returns a string, then we print it
    let message = "";
    if (user == "") {
        message = "Hello, stranger!";
    } else {
        message = "Hello, " + user + "!";
    }
    print(message);
}

print("Testing Option-like matching...");

const user1 = findUser(1);
const user2 = findUser(2);

print("greet(Alice): Expected: Hello, Alice!");
greet(user1);
print("greet(2): Expected: Hello, stranger!");
greet(user2);

// Nested matching with arrays
const item = [1, 2, 3];

let resultMatch = "Something else";
if (item.length > 0) {
    let x = item[0];
    let restLen = item.length - 1;
    resultMatch = "Array starts with " + x + ", rest has " + restLen + " elements";
} else if (item.length == 0) {
    resultMatch = "Empty array";
}

print("match([1,2,3]): Expected: starts with 1, rest 2, Actual: ", resultMatch);

print("Option tests completed.");

let libName = "TejX";
let libVersion = 1.0;

print("Testing template literals...");

// Basic interpolation
let greeting = `Hello, ${libName}!`;
print("greeting: Expected: Hello, TejX!, Actual: ", greeting);

// Multiple interpolations
let info = `Language: ${libName}, Version: ${libVersion}`;
print("info: Expected: Language: TejX, Version: 1, Actual: ", info);

// Expressions inside interpolation
let calc = `One plus one is ${1 + 1}`;
print("calc: Expected: One plus one is 2, Actual: ", calc);

// Nested template literals
let complex = `Value: ${`inner ${libName}`}`;
print("complex: Expected: Value: inner TejX, Actual: ", complex);

print("Template literals test complete!");

print("=== Object Spread Test ===");

// Base objects
let person = { name: "Alice", age: 30 };
let job = { title: "Engineer", salary: 100000 };

print("Person: Expected: [Object], Actual: ", person);
print("Job: Expected: [Object], Actual: ", job);

// Test 1: Spread one object into another
print("\n--- Test 1: Merge objects ---");
let employee = { ...person, ...job };
print("Employee: Expected: [Object] (Alice, Engineer), Actual: ", employee);

// Test 2: Spread with overrides
print("\n--- Test 2: Spread with overrides ---");
let updated = { ...person, age: 31, city: "NYC" };
print("Updated: Expected: [Object] (Alice, 31, NYC), Actual: ", updated);

// Test 3: Empty object with spread
print("\n--- Test 3: Spread into empty ---");
let copy = { ...person };
print("Copy: Expected: [Object] (Alice, 30), Actual: ", copy);

print("\n=== Object Spread Test Complete ===");
