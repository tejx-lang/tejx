// tests/async_scenarios.tx
// Complex Async/Await Scenarios

print("=== Async Scenarios Test ===");

// 1. Nested Awaits
// Validates that await correctly pauses execution at each level.
async function level1(x: int): Promise<int> {
    return x + 1;
}

async function level2(x: int): Promise<int> {
    let v = await level1(x);
    return v * 2;
}

async function level3(x: int): Promise<int> {
    let v = await level2(x);
    return v + 3;
}

async function testNested() {
    print("--- Nested Awaits ---");
    // level3(5) -> level2(5) -> level1(5) returns 6
    // level2 returns 6 * 2 = 12
    // level3 returns 12 + 3 = 15
    let result = await level3(5);
    print("Nested Result: Expected: 15, Actual: ", result);
    assert(result == 15);
}

// 2. Loop Awaits (Sequential)
// Validates that await inside a loop pauses the loop iteration.
async function delayAndReturn(ms: int, val: int): Promise<int> {
    // Assuming sleep/delay is not strictly available in pure logic, 
    // but the mechanics of async switching are tested here.
    // In a real env with timer we'd sleep.
    // Here we just yield via Promise resolution.
    return val;
}

async function testLoopSequence() {
    print("--- Loop Sequence ---");
    let sum = 0;
    for (let i = 1; i <= 3; i++) {
        print("Loop start ", i);
        let v = await delayAndReturn(10, i);
        sum = sum + v;
        print("Loop end ", i);
    }
    print("Loop Sum: Expected: 6, Actual: ", sum);
    assert(sum == 6);
}

// 3. Promise.all with Mixed Types
// Validates that Promise.all handles both Promises and non-Promises.
async function testPromiseAllMixed() {
    print("--- Promise.all Mixed ---");
    let p1 = level1(10); // Returns 11
    let val = 20;
    let p2 = level1(30); // Returns 31
    
    // Note: NovaJs Promise.all currently might expect Array<Promise<T>> or Array<Any>.
    // If implementation supports mixing, this should work.
    let results = await Promise.all([p1, val, p2]);
    
    print("Result 0: Expected: 11, Actual: ", results[0]);
    print("Result 1: Expected: 20, Actual: ", results[1]);
    print("Result 2: Expected: 31, Actual: ", results[2]);
    
    assert(results[0] == 11);
    assert(results[1] == 20);
    assert(results[2] == 31);
}

// 4. Recursive Async
// Validates async recursion stack.
async function asyncFactorial(n: int): Promise<int> {
    if (n <= 1) return 1;
    let prev = await asyncFactorial(n - 1);
    return n * prev;
}

async function testRecursion() {
    print("--- Async Recursion ---");
    let fact5 = await asyncFactorial(5);
    print("Factorial(5): Expected: 120, Actual: ", fact5);
    assert(fact5 == 120);
}

// Run all
await testNested();
await testLoopSequence();
await testPromiseAllMixed();
await testRecursion();
print("=== Async Scenarios Complete ===");
