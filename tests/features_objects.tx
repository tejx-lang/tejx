function run(): void {
    console.log("--- Object Literal Test ---");
    
    // Create Object
    let user: object = {
        name: "TejX",
        age: 1.0,
        active: true
    };
    
    // Access Properties
    console.log("Name: ", user["name"]);
    console.log("Age: ", user["age"]);
    
    // Dynamic Access
    let key: string = "active";
    // console.log("Active: ", user[key]); // Need to verify if this works with Variant logic

    console.log("--- End Test ---");
}

run();
// Nested Objects Test
let o = { 
    name: "Outer", 
    inner: { 
        name: "Inner", 
        val: 42 
    },
    list: [1, 2, 3]
};

console.log(o);
// console.log("Inner Val: ", o.inner.val); // Dot access on dynamic objects requires type checking or different CodeGen
// Used bracket notation which is guaranteed for maps
console.log("Inner Name: ", o["inner"]["name"]);
console.log("List[1]: ", o["list"][1]);

// Mixed types in array? Not supported by ArrayLiteral yet unless typed as []
// let mixed = [1, "a"]; // This would fail in ArrayLiteral generation
function runProfile(): void {
    console.log("--- Profile Test ---");
    
    let profile: { username: string, active: boolean, id: number } = {
        username: "TejXUser",
        active: true,
        id: 101
    };
    
    console.log("User: ", profile.username);
    console.log("Active: ", profile.active); // Tests string + bool
    console.log("ID: ", profile.id);
    console.log("--- End Profile Test ---");
}
runProfile();
