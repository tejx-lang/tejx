function run(): void {
    print("--- Object Literal Test ---");
    
    // Create Object
    let user: object = {
        name: "TejX",
        age: 1.0,
        active: true
    };
    
    // Access Properties
    print("Name: Expected: TejX, Actual: ", user["name"]);
    print("Age: Expected: 1, Actual: ", user["age"]);
    
    print("--- End Test ---");
}

run();
// Nested Objects Test
let o = { 
    name: "Outer", 
    inner: { 
        name: "Inner", 
        val: 42 
    },
    list: [1, 2, 3]
};

print("Object 'o': Expected: [Object], Actual: ", o);
// Used bracket notation which is guaranteed for maps
print("Inner Name: Expected: Inner, Actual: ", o["inner"]["name"]);
print("List[1]: Expected: 2, Actual: ", o["list"][1]);

function runProfile(): void {
    print("--- Profile Test ---");
    
    let profile: { username: string, active: boolean, id: number } = {
        username: "TejXUser",
        active: true,
        id: 101
    };
    
    print("User: Expected: TejXUser, Actual: ", profile.username);
    print("Active: Expected: 1/true, Actual: ", profile.active);
    print("ID: Expected: 101, Actual: ", profile.id);
    print("--- End Profile Test ---");
}
runProfile();
