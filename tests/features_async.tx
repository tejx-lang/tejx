// Async Features: Async/Await, Promises
// =======================================

console.log("--- Async Functions & Promises ---");

// 1. Basic Async Function
async function fetchData(id: number): Promise<string> {
    // Simulating a delay or network request
    // In a real scenario, this might await a timer or I/O
    return "Data for ID: " + id;
}

// 2. Formatting Data (Async)
async function formatData(data: string): Promise<string> {
    return "Formatted: [" + data + "]";
}

// 3. Main execution using await
async function runAsyncDemo(): Promise<void> {
    console.log("Fetching data...");
    
    // Await expression
    let data = await fetchData(42);
    console.log("Received: ", data);

    // Chaining awaits
    let result = await formatData(await fetchData(100));
    console.log("Chained Result: ", result);

    // Concurrent-like execution (sequentially awaited here)
    let p1 = fetchData(1);
    let p2 = fetchData(2);
    
    console.log("Both requests started...");
    
    let r1 = await p1;
    let r2 = await p2;
    
    console.log("R1: ", r1);
    console.log("R2: ", r2);
}

// Execute
// Note: Top-level await might not be supported depending on the runtime environment,
// so wrapping in a run function is safer.
runAsyncDemo();
// Async/Await Test - Awaited vs Un-awaited Promises

async function compute(x: number): Promise<number> {
    return x * 2;
}

async function delayedHello(): Promise<string> {
    return "Hello from async!";
}

console.log("=== Async/Await Tests ===");

// Test 1: Un-awaited promise (should show [Promise])
let unawaitedResult = compute(21);
console.log("Un-awaited result: ", unawaitedResult);  // Should print [Promise]

// Test 2: Awaited promise (should show actual value)
let awaitedResult = await compute(21);
console.log("Awaited result: ", awaitedResult);  // Should print 42

// Test 3: String promise un-awaited
let unawaitedStr = delayedHello();
console.log("Un-awaited string: ", unawaitedStr);  // Should print [Promise]

// Test 4: String promise awaited
let awaitedStr = await delayedHello();
console.log("Awaited string: ", awaitedStr);  // Should print "Hello from async!"

console.log("=== Async Tests Complete ===");
// Promise Features Test

console.log("=== Promise Features Test ===");

// Test 1: Basic async function with Promise<number>
async function computeDouble(x: number): Promise<number> {
    return x * 2;
}

// Test 2: Async function with Promise<string>
async function fetchGreeting(name: string): Promise<string> {
    return "Hello, " + name + "!";
}

// Test 3: Async function with delayed computation
async function slowAdd(a: number, b: number): Promise<number> {
    return a + b;
}

// === Test Un-awaited Promises ===
console.log("\n--- Un-awaited Promises ---");
let promise1 = computeDouble(5);
console.log("promise1 (not awaited): ", promise1);  // [Promise]

let promise2 = fetchGreeting("TejX");
console.log("promise2 (not awaited): ", promise2);  // [Promise]

// === Test Awaited Promises ===
console.log("\n--- Awaited Promises ---");
let result1 = await computeDouble(5);
console.log("result1 (awaited): ", result1);  // 10

let result2 = await fetchGreeting("TejX");
console.log("result2 (awaited): ", result2);  // Hello, TejX!

let result3 = await slowAdd(10, 20);
console.log("result3 (awaited): ", result3);  // 30

// === Test Chained Promises ===
console.log("\n--- Chained Promises ---");
let chainResult = await computeDouble(await computeDouble(5));
console.log("chainResult (double of double): ", chainResult);  // 20

// === Test Promise in Expression ===
console.log("\n--- Promise in Expression ---");
let exprResult = await computeDouble(3) + await computeDouble(7);
console.log("exprResult (3*2 + 7*2): ", exprResult);  // 20

console.log("\n=== Promise Features Test Complete ===");
// Promise Constructor Test - JS-style new Promise((resolve) => {...})

console.log("=== Promise Constructor Test ===");

// Test 1: Basic Promise with immediate resolve
console.log("\n--- Test 1: Immediate resolve ---");
let p1 = new Promise((resolve) => {
    resolve(42);
});
let r1 = await p1;
console.log("Resolved: ", r1);  // 42

// Test 2: Promise with computation before resolve
console.log("\n--- Test 2: Computed resolve ---");
let p2 = new Promise((resolve) => {
    let x = 10;
    let y = 20;
    resolve(x + y);
});
let r2 = await p2;
console.log("Computed result: ", r2);  // 30

// Test 3: Promise with string
console.log("\n--- Test 3: String resolve ---");
let p3 = new Promise((resolve) => {
    resolve("Hello from Promise!");
});
let r3 = await p3;
console.log("String: ", r3);

// Test 4: Un-awaited promise shows [Promise]
console.log("\n--- Test 4: Un-awaited shows [Promise] ---");
let p4 = new Promise((resolve) => {
    resolve(100);
});
console.log("Un-awaited: ", p4);  // [Promise]

console.log("\n=== Promise Constructor Test Complete ===");

async function testConcurrency() {
    console.log("Start: ", Date.now());
    
    // Test Delay
    console.log("Waiting 100ms...");
    await delay(100);
    console.log("Buffered: ", Date.now());
    
    // Test Promise.all
    console.log("Testing Promise.all...");
    let start = Date.now();
    let results = await Promise.all([
        delay(50),
        delay(100),
        "Instant"
    ]);
    console.log("Promise.all done in: ", (Date.now() - start), "ms (approx 100)");
    console.log("Results length: ", results.length);
    console.log("Results[2]: ", results[2]);

    // Test HTTP (Assume network or just check compilation/runtime)
    // We'll trust curl is present.
    console.log("Fetching Google...");
    let html = await http.get("https://www.google.com");
    if (html.length > 0) {
        console.log("Fetched Google! Size: ", html.length);
    } else {
        console.log("Fetch failed or empty (no network?)");
    }
}

// Run async function
testConcurrency();
