// Async Features: Async/Await, Promises
// =======================================

// 1. Basic Async Function
async function fetchData(id: int32): Promise<string> {
    return "Data for ID: " + id;
}

// 2. Formatting Data (Async)
async function formatData(data: string): Promise<string> {
    return "Formatted: [" + data + "]";
}

async function compute(x: int32): Promise<int32> {
    return x * 2;
}

async function delayedHello(): Promise<string> {
    return "Hello from async!";
}

// Basic async function with Promise<int32>
async function computeDouble(x: int32): Promise<int32> {
    return x * 2;
}

// Async function with Promise<string>
async function fetchGreeting(name: string): Promise<string> {
    return "Hello, " + name + "!";
}

// Async function with delayed computation
async function slowAdd(a: int32, b: int32): Promise<int32> {
    return a + b;
}

async function main(): Promise<void> {
    print("--- Async Functions & Promises ---");

    print("Fetching data...");
    
    // Await expression
    let data = await fetchData(42);
    print("Received: Expected: Data for ID: 42, Actual: ", data);

    // Chaining awaits
    let result = await formatData(await fetchData(100));
    print("Chained Result: Expected: Formatted: [Data for ID: 100], Actual: ", result);

    // Concurrent-like execution (sequentially awaited here)
    let p1 = fetchData(1);
    let p2 = fetchData(2);
    
    print("Both requests started...");
    
    let r1 = await p1;
    let r2 = await p2;
    
    print("R1: Expected: Data for ID: 1, Actual: ", r1);
    print("R2: Expected: Data for ID: 2, Actual: ", r2);

    print("=== Async/Await Tests ===");

    // Test 1: Un-awaited promise (should show [Promise])
    let unawaitedResult = compute(21);
    print("Un-awaited result: Expected: [Promise]/[Object], Actual: ", unawaitedResult); 

    // Test 2: Awaited promise (should show actual value)
    let awaitedResult = await compute(21);
    print("Awaited result: Expected: 42, Actual: ", awaitedResult);

    // Test 3: String promise un-awaited
    let unawaitedStr = delayedHello();
    print("Un-awaited string: Expected: [Promise]/[Object], Actual: ", unawaitedStr);

    // Test 4: String promise awaited
    let awaitedStr = await delayedHello();
    print("Awaited string: Expected: Hello from async!, Actual: ", awaitedStr);

    print("=== Async Tests Complete ===");

    print("=== Promise Features Test ===");

    // === Test Un-awaited Promises ===
    print("--- Un-awaited Promises ---");
    let promise1 = computeDouble(5);
    print("promise1 (not awaited): Expected: [Promise]/[Object], Actual: ", promise1);

    let promise2 = fetchGreeting("TejX");
    print("promise2 (not awaited): Expected: [Promise]/[Object], Actual: ", promise2);

    // === Test Awaited Promises ===
    print("--- Awaited Promises ---");
    let result1 = await computeDouble(5);
    print("result1 (awaited): Expected: 10, Actual: ", result1);

    let result2 = await fetchGreeting("TejX");
    print("result2 (awaited): Expected: Hello, TejX!, Actual: ", result2);

    let result3 = await slowAdd(10, 20);
    print("result3 (awaited): Expected: 30, Actual: ", result3);

    // === Test Chained Promises ===
    print("--- Chained Promises ---");
    let chainResult = await computeDouble(await computeDouble(5));
    print("chainResult: Expected: 20, Actual: ", chainResult);

    // === Test Promise in Expression ===
    print("--- Promise in Expression ---");
    let exprResult = await computeDouble(3) + await computeDouble(7);
    print("exprResult (3*2 + 7*2): Expected: 20, Actual: ", exprResult);

    print("=== Promise Features Test Complete ===");

    print("=== Promise Constructor Test ===");
    print("=== Promise Constructor Test Complete ===");

    print("Start (Timestamp): ", Date.now());
    
    // Test Delay
    print("Waiting 100ms...");
    await delay(100);
    print("Buffered: Expected: > Start, Actual: ", Date.now());
    
    // Test Promise.all
    print("Testing Promise.all...");
    let start = Date.now();
    let results = await Promise.all([
        delay(50),
        delay(100),
        "Instant"
    ]);
    print("Promise.all done in: Expected: ~100ms, Actual: ", (Date.now() - start), "ms");
    print("Results length: Expected: 3, Actual: ", results.length);
    print("Results[2]: Expected: Instant, Actual: ", results[2]);

    print("Fetching Google...");
    let html = await http.get("https://www.google.com");
    if (html.length > 0) {
        print("Fetched Google! Expected: Length > 0, Actual: ", html.length);
    } else {
        print("Fetch failed or empty: Actual: empty/0");
    }
}
