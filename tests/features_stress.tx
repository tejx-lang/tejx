// tests/features_stress.tx
// Complex scenarios and stress tests for NovaJs feature set.

print("=== NovaJs Stress Test ===");

// 1. Deep Recursion (Ackermann Function)
// A(m, n) =
//   n + 1                  if m = 0
//   A(m - 1, 1)            if m > 0 and n = 0
//   A(m - 1, A(m, n - 1))  if m > 0 and n > 0

function ackermann(m: number, n: number): number {
    if (m == 0) {
        return n + 1;
    } else if (n == 0) {
        return ackermann(m - 1, 1);
    } else {
        return ackermann(m - 1, ackermann(m, n - 1));
    }
}

print("\n--- Deep Recursion (Ackermann) ---");
// A(3, 2) -> 29. A(3, 3) -> 61. A(4, 1) -> 65533 (too deep for stack?)
// Let's try A(3, 2) safe for standard stack.
let m = 2;
let n = 2;
print("Calculating Ackermann(2, 2)...");
let result = ackermann(2, 2);
print("Ackermann(2, 2) =", result);
assert(result == 7);


// 3. Higher-Order Functions / Closures (Simulated with Class)
// Closures capturing variables are not fully supported yet in lowering.
// We use a Class to simulate stateful behavior, which is robust.

class Counter {
    state: number;
    
    constructor(start: number) {
        this.state = start;
    }
    
    increment(): number {
        this.state = this.state + 1;
        return this.state;
    }
    
    getValue(): number {
        return this.state;
    }
}

function makeCounter(start: number): Counter {
    return new Counter(start);
}

// Simple Arrow Function (Stateless)
let double = (x: number) => x * 2;
print(`Arrow Function Test: double(10) = ${double(10)}`);
assert(double(10) == 20);

let counter = makeCounter(10);
print(`Initial: ${counter.getValue()}`);
print(`Inc 1: ${counter.increment()}`);
print(`Inc 2: ${counter.increment()}`);
assert(counter.getValue() == 12);


// 3. Complex Object & Array Manipulation
print("\n--- Complex Data Structures ---");
let matrix = [
    [1, 2, 3],
    [4, 5, 6],
    [7, 8, 9]
];

// Matrix multiplication with vector v = [1, 2, 3]
let v = [1, 2, 3];
let result = [0, 0, 0];

for (let r = 0; r < 3; r++) {
    let row = matrix[r];
    let sum = 0;
    for (let c = 0; c < 3; c++) {
        sum = sum + (row[c] * v[c]);
    }
    result[r] = sum;
}

print(`Matrix * Vector result: [${result[0]}, ${result[1]}, ${result[2]}]`);
// Expected:
// 1*1 + 2*2 + 3*3 = 1+4+9 = 14
// 4*1 + 5*2 + 6*3 = 4+10+18 = 32
// 7*1 + 8*2 + 9*3 = 7+16+27 = 50
assert(result[0] == 14);
assert(result[1] == 32);
assert(result[2] == 50);

// 4. Large Loop Performance (Stress)
print("\n--- Large Loop Performance ---");
let sum = 0;
let limit = 100000;
import std:time;
let start = now();

for (let i = 1; i <= limit; i++) {
    sum = sum + i;
}
let end = now();
let duration = end - start;

print(`Sum 1 to ${limit}: ${sum}`);
// Sum = n(n+1)/2 = 100000 * 100001 / 2 = 5000050000
// Note: 5 billion fits in 64-bit int/float.
print(`Time: ${duration}ms`);
// assert(sum == 5000050000); // Check formatting/precision


print("\n=== Stress Test Complete ===");
