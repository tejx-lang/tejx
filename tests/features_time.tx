
import std:time;

async function test_delay() {
    print("Starting delay(500)...");
    let t1 = time.now();
    await time.delay(500);
    let t2 = time.now();
    let d = t2 - t1;
    print("Delay finished. Diff: " + d + "ms");
    print("Delay finished. Diff: " + d + "ms");
    assert(d >= 500);
}

async function main() {
    print("--- Testing Time Module ---");

    // Test now()
    let start = time.now();
    print("Current timestamp: " + start);
    assert(start > 1600000000000); // Sanity check (year > 2020)

    // Test sleep()
    print("Sleeping for 500ms (blocking)...");
    time.sleep(500);
    let end = time.now();
    let diff = end - start;
    print("Woke up. Diff: " + diff + "ms");
    assert(diff >= 500);

    // Run async test
    await test_delay();
    print("Async delay test passed");
}
