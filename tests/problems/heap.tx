import { MaxHeap } from "std:collections";

function main(): void {
  // A Max-Heap: always returns the largest number
  let pq: MaxHeap<int> = new MaxHeap<int>();

  pq.insertMax(10);
  pq.insertMax(100);
  pq.insertMax(50);

  let max1 = pq.extractMax();
  print("Extract Max 1: Expected: 100, Actual: ", max1);
  
  let max2 = pq.extractMax();
  print("Extract Max 2: Expected: 50, Actual: ", max2);
  
  let max3 = pq.extractMax();
  print("Extract Max 3: Expected: 10, Actual: ", max3);
}
