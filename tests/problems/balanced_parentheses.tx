import { Stack } from "std:collections";

function assert(condition: bool, message: string): void {
  if (!condition) {
    print("❌ FAIL: ", message);
    throw new Error("AssertionFailed: " + message);
  } else {
    print("✅ PASS: ", message);
  }
}

function isBalanced(expr: string): bool {
  let s: Stack<char> = new Stack<char>();
  print("Checking expr:", expr);
  
  for (let i = 0; i < expr.length(); i++) {
    let c = expr[i] as char;
    if (c == "(" as char || c == "[" as char || c == "{" as char) {
      s.push(c);
    } else {
      if (s.isEmpty()) { return false; }
      let top = s.pop();
      if ((c == ")" as char && top != "(" as char) || 
          (c == "]" as char && top != "[" as char) || 
          (c == "}" as char && top != "{" as char)) {
        return false;
      }
    }
  }
  return s.isEmpty();
}

function main(): void {
  assert(isBalanced("{[()]}") == true, "Balanced string should return true");
  assert(isBalanced("{[(])}") == false, "Unbalanced string should return false");
  print("Finished balanced_parentheses.");
}
