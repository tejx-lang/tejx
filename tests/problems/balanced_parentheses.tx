import { Stack } from "std:collections";

function isBalanced(expr: string): bool {
  let s: Stack<char> = new Stack();
  
  for (let i = 0; i < expr.length; i++) {
    let c = expr[i];
    if (c == "(" || c == "[" || c == "{") {
      s.push(c);
    } else {
      if (s.isEmpty()) return false;
      let top = s.pop();
      if ((c == ")" && top != "(") || 
          (c == "]" && top != "[") || 
          (c == "}" && top != "{")) {
        return false;
      }
    }
  }
  return s.isEmpty();
}

function main(): void {
  let res1 = isBalanced("{[()]}");
  print("isBalancedValid: Expected: true, Actual: ", res1);

  let res2 = isBalanced("{[(])}");
  print("isBalancedInvalid: Expected: false, Actual: ", res2);
}


