import { Map, Set, Queue } from "std:collections";

function bfs(graph: Map<string, string[]>, start: string): void {
  let visited: Set<string> = new Set();
  let q: Queue<string> = new Queue();

  q.enqueue(start);
  visited.add(start);

  let result: string[] = [];
  while (!q.isEmpty()) {
    let current = q.dequeue();
    result.push(current);

    let neighbors = graph.get(current);
    if (neighbors != None) {
      for (let i = 0; i < neighbors.length; i++) {
        let next = neighbors[i];
        if (!visited.has(next)) {
          visited.add(next);
          q.enqueue(next);
        }
      }
    }
  }
  
  print("BFS Traversal: Expected: [A, B, C, D, E, F], Actual: ", result);
}


function main() {
  let graph = new Map();

  graph.set("A", ["B", "C"]);
  graph.set("B", ["D", "E"]);
  graph.set("C", ["F"]);
  graph.set("D", []);
  graph.set("E", ["F"]);
  graph.set("F", []);

  bfs(graph, "A");
}
