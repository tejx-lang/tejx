import { SharedQueue, Mutex } from "std:thread";

function producer(q: SharedQueue<int>, mutex: Mutex): void {
  for (let i = 0; i < 100; i++) {
    mutex.lock();
    q.enqueue(i);
    mutex.unlock();
  }
}

function consumer(q: SharedQueue<int>, mutex: Mutex): void {
  let count = 0;
  while (count < 100) {
    mutex.lock();
    if (!q.isEmpty()) {
      let val = q.dequeue();
      print("Consumed:", val);
      count++;
    }
    mutex.unlock();
  }
}

function main(): void {
  let q = new SharedQueue<int>();
  let mutex = new Mutex();
  let producerThread = new Thread(producer, q, mutex);
  let consumerThread = new Thread(consumer, q, mutex);
  producerThread.join();
  consumerThread.join();
  print("Producer and consumer finished.");
}
