import { Thread, SharedQueue, Mutex } from "std:thread";

function main(): void {
  let q = new SharedQueue<int>();
  let mutex = new Mutex();
  let producerThread = new Thread(() => {
    for (let i = 0; i < 100; i++) {
      mutex.lock();
      q.enqueue(i);
      mutex.unlock();
    }
  });
  let consumerThread = new Thread(() => {
    let count = 0;
    while (count < 100) {
      mutex.lock();
      if (!q.isEmpty()) {
        let val = q.dequeue();
        print("Consumed:", val);
        count++;
      }
      mutex.unlock();
    }
  });
  producerThread.join();
  consumerThread.join();
  print("Producer and consumer finished.");
}
