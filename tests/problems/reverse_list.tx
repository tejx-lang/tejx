import {assert_eq_int} from "../positive/utils.tx";
class Node {
  data: int;
  next: Node | None;
  constructor(val: int) { 
      this.data = val; 
      this.next = None;
  }
}

// Reverse a linked list
function reverseList(head: Node | None): Node | None {
  let prev: Node | None = None;
  let current: Node | None = head;
  let next: Node | None = None;


  let loopCount = 0;
  while (!(current == None)) {
    loopCount = loopCount + 1;
    
    if (loopCount > 5) {
        print("Runaway loop!");
        break;
    }

    next = current.next;     
    current.next = prev;     
    prev = current;          
    current = next;          
  }
  return prev; 
}



function main(): void {
  let n1 = new Node(1);
  let n2 = new Node(2);
  let n3 = new Node(3);
  
  n2.next = n3;
  n1.next = n2;

  let head = reverseList(n1);
  
  print("New Head ID:", head);

  print("Reversed List Check:");
     assert_eq_int(head.data, 3, "Head data is not 3");

  if (head != None) {
      if (head.data == 3) {
           // Traverse
           let second = head.next;
            assert_eq_int(second.data, 2, "Second data is not 2");

           if (second != None) {
             let third = second.next;
             assert_eq_int(third.data, 1, "Third data is not 1");

             if (third != None) { 
               assert_true(third.next == None, "Tail Next is NOT None!");

                 if (third.next == None) {
                  print("Tail Correct");
                 } else {
                     print("Tail Next is NOT None!");
                 }
             }
           }
      } else {
          print("Head data Wrong! Found:", head.data);
      }
  } else {
     // assert(false, "Head is None!");
     print("Head is None");
  }
}
