import {assert_eq_int, assert_true} from "../positive/utils.tx";
class Node {
  data: int;
  next: Optional<Node>;
  constructor(val: int) { 
      this.data = val; 
      this.next = None;
  }
}

// Reverse a linked list
function reverseList(head: Optional<Node>): Optional<Node> {
  let prev: Optional<Node> = None;
  let current: Optional<Node> = head;
  let next: Optional<Node> = None;


  let loopCount = 0;
  while (current != None) {
    loopCount = loopCount + 1;
    
    if (loopCount > 5) {
        print("Runaway loop!");
        break;
    }

    next = current.next;     
    current.next = prev;     
    prev = current;          
    current = next;          
  }
  return prev; 
}



function main(): void {
  let n1 = new Node(1);
  let n2 = new Node(2);
  let n3 = new Node(3);
  
  n2.next = n3;
  n1.next = n2;

  let head = reverseList(n1);
  
  print("New Head ID:", head);

  print("Reversed List Check:");
  if (head != None) {
      assert_eq_int(3, head.data, "Head data is not 3");
      if (head.data == 3) {
           // Traverse
           let second = head.next;
           if (second != None) {
             assert_eq_int(2, second.data, "Second data is not 2");
             let third = second.next;
             if (third != None) { 
               assert_eq_int(1, third.data, "Third data is not 1");
               assert_true(third.next == None, "Tail Next is NOT None!");

               if (third.next == None) {
                print("Tail Correct");
               } else {
                   print("Tail Next is NOT None!");
               }
             }
           }
      } else {
          print("Head data Wrong! Found:", head.data);
      }
  } else {
     // assert(false, "Head is None!");
     print("Head is None");
  }
}
