class Point {
  x: float; y: float;
  constructor(x: float, y: float) { this.x = x; this.y = y; }
}

function orientation(p: Point, q: Point, r: Point): int {
  let val = (q.y - p.y) * (r.x - q.x) - (q.x - p.x) * (r.y - q.y);
  if (val == 0.0) return 0;  // Collinear
  return (val > 0.0) ? 1 : 2; // Clockwise or Counter-clockwise
}