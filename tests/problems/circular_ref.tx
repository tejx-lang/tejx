
class Person {
  friend: Person | None = None;
}

function leakTest(): void {
  let a = new Person();
  let b = new Person();
  a.friend = b;
  b.friend = a;
  print("Cycle created. Function exiting (GC should start).");
}

function main() {
  print("Constructing circular ref...");
  leakTest();
  print("Done.");
}