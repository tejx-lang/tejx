function lcs(text1: string, text2: string): int {
  let m = text1.length;
  let n = text2.length;
  // Create a 2D Array: dp[m+1][n+1]
  let dp: int[][] = new Array(m + 1);
  for (let i = 0; i <= m; i++) dp[i] = new Array(n + 1).fill(0);

  for (let i = 1; i <= m; i++) {
    for (let j = 1; j <= n; j++) {
      if (text1[i - 1] == text2[j - 1]) {
        dp[i][j] = dp[i - 1][j - 1] + 1;
      } else {
        let val1 = dp[i - 1][j];
        let val2 = dp[i][j - 1];
        dp[i][j] = val1 > val2 ? val1 : val2;
      }
    }
  }
  return dp[m][n];
}