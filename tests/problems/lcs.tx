import { assert } from "../positive/utils.tx";

function lcs(text1: string, text2: string): int {
  let m = text1.length;
  let n = text2.length;
  let dp:int[m+1][n+1] =[];
  for (let i = 0; i <= m; i++) {
    let tempArr:int[n+1]=[];
    dp[i] = tempArr.fill(0);
  }

  for (let i = 1; i <= m; i++) {
    for (let j = 1; j <= n; j++) {
      if (text1[i - 1] == text2[j - 1]) {
        dp[i][j] = dp[i - 1][j - 1] + 1;
      } else {
        let a = dp[i - 1][j];
        let b = dp[i][j - 1];
        if (a > b) dp[i][j] = a;
        else dp[i][j] = b;
      }
    }
  }
  return dp[m][n];
}

function main(): void {
  let res = lcs("abcde", "ace");
  print("LCS Result: ", res);
  assert(res == 3, "LCS of abcde and ace should be 3");
}