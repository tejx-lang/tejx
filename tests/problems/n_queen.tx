function solveNQueens(n: int): void {
  let board: string[][] = new Array(n);
  for(let i = 0; i < n; i++) board[i] = new Array(n).fill(".");

  function isSafe(row: int, col: int): bool {
    for (let i = 0; i < col; i++) if (board[row][i] == "Q") return false;
    for (let i = row, j = col; i >= 0 && j >= 0; i--, j--) if (board[i][j] == "Q") return false;
    for (let i = row, j = col; j >= 0 && i < n; i++, j--) if (board[i][j] == "Q") return false;
    return true;
  }

  function backtrack(col: int): bool {
    if (col >= n) return true; // All queens placed

    for (let i = 0; i < n; i++) {
      if (isSafe(i, col)) {
        board[i][col] = "Q";
        if (backtrack(col + 1)) return true;
        board[i][col] = "."; // Backtrack
      }
    }
    return false;
  }

  let found = backtrack(0);
  print("N-Queens Solution (n=4): Expected: true, Actual: ", found);
  
  if (found) {
      // Validating first row for 4-queens (usually . Q . . or . . Q .)
      // One solution is . Q . . / ...
      print("Board generated."); 
  }
}solveNQueens(4);
