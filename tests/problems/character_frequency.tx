import { Map } from "std:collections";

function charCount(input: string): void {
  let counts: Map<string, int> = new Map();
  
  for (let i = 0; i < input.length; i++) {
    let c = "" + input[i]; // Convert char to string
    if (counts.has(c)) {
      counts.set(c, counts.get(c) + 1);
    } else {
      counts.set(c, 1);
    }
  }
  
  // Check specific counts
  print("'l' count: Expected: 3, Actual: ", counts.get("l"));
  print("'o' count: Expected: 2, Actual: ", counts.get("o"));
  
  let keys = counts.keys();
  print("Unique chars: Expected: 8, Actual: ", keys.length);
}

charCount("hello world");