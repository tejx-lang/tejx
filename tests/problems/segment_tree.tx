class SegNode {
  val: int;
  left: SegNode | null;
  right: SegNode | null;
  constructor(v: int, l: SegNode, r: SegNode) { /* ... */ }
}

function update(node: SegNode, start: int, end: int, idx: int, val: int): SegNode {
  if (start == end) return new SegNode(val, null, null);
  
  let mid = (start + end) / 2;
  // Instead of modifying, we return a BRAND NEW path
  if (idx <= mid) {
    return new SegNode(node.val + val, update(node.left, start, mid, idx, val), node.right);
  } else {
    return new SegNode(node.val + val, node.left, update(node.right, mid + 1, end, idx, val));
  }
}