// Comprehensive Error Handling Test
// =====================================

class CustomError extends Error {
    code: int32;
    constructor(m: string, c: int32) {
        super(m);
        this.code = c;
    }
}

function process(x: int32) {
    if (x < 0) {
        throw new CustomError("Negative input", 400);
    }
    if (x == 0) {
        throw "Zero is not allowed";
    }
    return 100 / x;
}

print("Testing Proper Error Handling...");

// Scenario 1: Throwing a string
try {
    process(0);
} catch (e) {
    print("Caught string: Expected: Zero is not allowed, Actual: ", e);
} finally {
    print("Cleanup 1: Expected: pass, Actual: pass");
}

// Scenario 2: Throwing an object (CustomError)
try {
    process(-5);
} catch (e) {
    print("Caught object: Expected: Negative input (Code: 400), Actual: ", e.message, " (Code: ", e.code, ")");
    print("ToString: Expected: Error: Negative input, Actual: ", e.toString());
} finally {
    print("Cleanup 2: Expected: pass, Actual: pass");
}

// Scenario 3: Nested try/catch and RAII finally
function nestedTest() {
    print("\n--- Nested Try/Catch ---");
    try {
        print("Entering outer try: Expected: pass, Actual: pass");
        try {
            print("Entering inner try: Expected: pass, Actual: pass");
            process(-1);
        } catch (innerErr) {
             print("Inner catch: Expected: Negative input, Actual: ", innerErr.message);
             // Rethrow
             throw innerErr;
        } finally {
            print("Inner finally: Expected: pass, Actual: pass");
        }
    } catch (err) {
        print("Outer catch (rethrow): Expected: Negative input, Actual: ", err.message);
    } finally {
        print("Outer finally: Expected: pass, Actual: pass");
    }
}

nestedTest();

// Scenario 4: Error in Loop
print("\n--- Error in Loop ---");
for (let i = -2; i <= 2; i = i + 1) {
    try {
        if (i == 0) throw "Zero!";
        print("Result: ", 10/i);
    } catch (e) {
        print("Loop catch: ", e);
    }
}

print("Error handling test complete!");
