// Feature: Type Aliases

import { stringify } from "std:json";

type ID = int;
type Point = { x: int, y: int };
type Handler = (msg: string) => void;
// type Callback = function:void:string; // Alternate syntax removed as it's internal MIR representation
type Callback = (msg: string) => void;

function process(id: ID) {
    print("Processing ID: " + stringify(id));
}

let myId: ID = 123;
process(myId);

// Basic verification of aliases
// Note: Deep structural type checking for objects might not be fully implemented yet,
// but the parser should handle the syntax and type checker should allow the alias name.

print("Type aliases test passed");
