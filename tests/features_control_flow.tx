// Control Flow: If, Loop, Switch
// ================================

// 1. If / Else
function checkValue(n: number): void {
    console.log("Checking " + n);
    if (n > 10) {
        console.log("  Big");
    } else if (n > 5) {
        console.log("  Medium");
    } else {
        console.log("  Small");
    }
}

checkValue(15);
checkValue(3);

// 2. Loops
console.log("\n--- Loops ---");

// While Loop
console.log("While Loop:");
let idx = 0;
while (idx < 3) {
    console.log("  idx = " + idx);
    idx = idx + 1;
}

// For Loop (C-Style)
console.log("For Loop:");
for (let j = 0; j < 3; j = j + 1) {
    if (j == 1) continue; // Test continue
    console.log("  j = " + j);
}

// For-Of Loop (using forEach as for-of on Var (inferred) is currently limited)
console.log("For-Of Loop:");
let items = ["A", "B", "C"];
items.forEach(item => {
    console.log("  Item: " + item);
});

// Break Statement
console.log("Break Test:");
let k1 = 0;
while (true) {
    if (k1 >= 3) break;
    console.log("  k1 = " + k1);
    k1 = k1 + 1;
}

// 3. Switch Statement
console.log("\n--- Switch ---");
function getFruitColor(fruit: string): string {
    switch (fruit) {
        case "Apple":
            return "Red";
        case "Banana":
            return "Yellow";
        case "Grape":
            return "Purple";
        default:
            return "Unknown";
    }
}

console.log("Apple is " + getFruitColor("Apple"));
console.log("Banana is " + getFruitColor("Banana"));
console.log("Kiwi is " + getFruitColor("Kiwi"));
// examples/control.tx

let sumVal = 0;
// Test +=
sumVal += 10;
console.log("Sum should be 10: " + sumVal);

sumVal -= 5;
console.log("Sum should be 5: " + sumVal);

sumVal *= 2;
console.log("Sum should be 10: " + sumVal);

sumVal /= 2;
console.log("Sum should be 5: " + sumVal);

// Test ++ / --
let xVal = 0;
++xVal;
console.log("x should be 1: " + xVal);
--xVal;
console.log("x should be 0: " + xVal);

// Test Break
console.log("--- Break Test ---");
for (let i = 0; i < 10; i = i + 1) {
    if (i == 5) {
        break;
    }
    console.log("i: " + i);
}

// Test Continue
console.log("--- Continue Test ---");
for (let j = 0; j < 5; j = j + 1) {
    if (j == 2) {
        continue;
    }
    console.log("j: " + j);
}

// Test While Break
console.log("--- While Break Test ---");
let k = 0;
while (k < 10) {
    if (k == 3) {
        break;
    }
    console.log("k: " + k);
    k = k + 1;
}
// For-Of Loop Test (typed arrays)

console.log("Testing for-of loop (as forEach)...");

let numbers = [1, 2, 3, 4, 5];
let sum = 0;

numbers.forEach(n => {
    console.log("Number: " + n);
    sum = sum + n;
});

console.log("Sum: " + sum);

console.log("For-of loop test complete!");
// examples/logic.tx

let a = true;
let b = false;
let c = true;

// AND
if (a && c) {
    console.log("a && c is true");
} else {
    console.log("a && c is false");
}

// OR
if (a || b) {
    console.log("a || b is true");
}

if (b || b) {
    console.log("b || b is true");
} else {
    console.log("b || b is false");
}

// Complex
if ((a && b) || c) {
    console.log("(a && b) || c is true");
}

// Not Equal
let x2 = 10;
if (x2 != 20) {
    console.log("x != 20");
}

// Short-circuit Test
if (true || (1/0 == 0)) {
   console.log("Short-circuit works (no crash)");
}
function describe(val: any) {
    const result = match (val) {
        1 => "one",
        n if (n > 10) => "a large number: " + n,
        "hello" => "a greeting",
        true => "yes",
        undefined => "nothing",
        _ => "something else"
    };
    console.log("Input: " + val + " => Result: " + result);
}

function processArray(arr: any) {
    const result = match (arr) {
        [1, y] => "Starts with 1, second is " + y,
        [x, 2] => "Ends with 2, first is " + x,
        [first, ...rest] if (rest.length > 0) => "Starts with " + first + ", rest size: " + rest.length,
        [a, b, c] => "Three elements: " + a + ", " + b + ", " + c,
        _ => "Unknown array pattern"
    };
    console.log("Array: " + arr + " => " + result);
}

function processObject(obj: any) {
    const result = match (obj) {
        { name: n, age: a } => n + " is " + a + " years old",
        { status: s } => "Status is " + s,
        _ => "Unknown object"
    };
    console.log("Object: " + obj + " => " + result);
}

function processComplex(val: any) {
    const result = match (val) {
        [[x, ...y], ...rest] => "Nested head: " + x + ", sub-rest: " + y.length + ", outer rest: " + rest.length,
        { details: { score: s } } if (s >= 90) => "High score: " + s,
        { details: { score: s } } => "Regular score: " + s,
        [first, ...rest] if (rest.length == 0) => "Single element array: " + first,
        _ => "Other complex case"
    };
    console.log("Complex: " + val + " => " + result);
}

console.log("--- Match Expression Test ---");
describe(1);
describe(42);
describe("hello");
describe(false);
describe(undefined);

processArray([1, 42]);
processArray([99, 2]);
processArray([10, 20, 30]);
processArray([1, 2, 3]);
processArray([1]);

processObject({ name: "Alice", age: 30 });
processObject({ status: "active" });
processObject({ foo: "bar" });

processComplex([[1, 2, 3], 4, 5]);
processComplex({ details: { score: 95 } });
processComplex({ details: { score: 70 } });
processComplex([100]);
processComplex("random");
