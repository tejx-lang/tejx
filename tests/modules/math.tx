export const VERSION = "1.0.0";

export function add(a: float64, b: float64): float64 {
    return a + b;
}

export function multiply(a: float64, b: float64): float64 {
    return a * b;
}

export class Calculator {
    value: float64 = 0;
    
    add(n: float64) {
        this.value = this.value + n;
    }
    
    getValue(): float64 {
        return this.value;
    }
}
