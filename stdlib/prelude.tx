export function RT_Array_fill<T>(arr: Array<T>, val: T): Array<T> {
    for (let i = 0; i < len(arr); i++) {
        arr[i] = val;
    }
    return arr;
}

export function RT_Array_sliceRest<T>(arr: Array<T>, start: int): Array<T> {
    let res: Array<T> = [];
    for (let i = start; i < len(arr); i++) {
        res.push(arr[i]);
    }
    return res;
}
