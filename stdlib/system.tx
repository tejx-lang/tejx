extern function rt_exit(code: int): void;
extern function rt_getenv(key: string): string;
extern function rt_args(): string[];

export function exit(code: int): void {
    rt_exit(code);
}

export function env(key: string): string {
    return rt_getenv(key);
}

export function args(): string[] {
    return rt_args();
}

// Aliases
export function argv(): string[] { return args(); }
export function getEnv(key: string): string { return env(key); }
