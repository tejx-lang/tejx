// Multithreading Test

let m = new Mutex();
let count = 0;

console.log("Starting threads test...");

let t1 = new Thread(() => {
    m.lock();
    count = count + 1;
    console.log("Thread 1 done: " + count);
    m.unlock();
});

let t2 = new Thread(() => {
    m.lock();
    count = count + 1;
    console.log("Thread 2 done: " + count);
    m.unlock();
});

t1.join();
t2.join();

console.log("Final count: " + count);
console.log("Threads test complete!");
