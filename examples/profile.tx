function run(): void {
    console.log("--- Profile Test ---");
    
    let profile: { username: string, active: boolean, id: number } = {
        username: "TejXUser",
        active: true,
        id: 101
    };
    
    console.log("User: " + profile.username);
    console.log("Active: " + profile.active); // Tests string + bool
    console.log("ID: " + profile.id);
    console.log("--- End Profile Test ---");
}
run();
